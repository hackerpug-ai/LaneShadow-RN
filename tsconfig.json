{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "vitest.d.ts",
    "shared/**/*"
  ],
  "exclude": [
    "workers/**",
    "scripts/**",
    "_archived/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "convex/actions/**",
    "convex/db/**",
    "convex/lib/**",
    "convex/migrations/**",
    "convex/models/**",
    "convex/queries/**",
    "convex/util/**",
    "convex/__fixtures__/**",
    "convex/__tests__/**",
    "convex/*.ts",
    "shared/lib/storage/**",
    "simple-*.test.*",
    "test-syntax-simple.ts",
    "stories/**"
  ]
}
