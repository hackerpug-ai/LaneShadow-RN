*,*::before,*::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --paper-50:  #FDFBF8;
  --paper-100: #F8F7F6;
  --paper-150: #F5F2EE;
  --paper-200: #F2EFED;
  --paper-300: #EDE7E1;
  --paper-400: #E5DED9;
  --paper-500: #C9BDB3;
