+import LaneShadowTheme
+import NativeSandbox
+import SwiftUI
+
+@MainActor
+enum LSListRowStory {
+    static let all: [Story] = [
+        Story(
+            id: "molecules.listRow.leadingIcon",
+            tier: .molecule,
+            component: "LSListRow",
+            name: "Leading Icon",
+            summary: "List row with icon-leading content and static trailing icon."
