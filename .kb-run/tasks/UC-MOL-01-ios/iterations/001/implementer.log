+        ) { _ in
+            LSContentCard(
+                title: "Emigration Canyon Climb",
+                subtitle: "28 mi · 1h 04m · Mountain",
+                metadata: ["3,400 ft gain", "Last ridden Apr 18"],
+                chips: ["Best Route", "Alpine"]
