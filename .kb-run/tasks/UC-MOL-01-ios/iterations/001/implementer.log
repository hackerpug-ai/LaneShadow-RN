+                header: AnyView(imageHeader),
+                actions: AnyView(
+                    HStack(spacing: Theme.shared.space.sm) {
+                        LSButton("Ride This", variant: .primary, action: {})
+                        LSButton("Save", variant: .ghost, action: {})
