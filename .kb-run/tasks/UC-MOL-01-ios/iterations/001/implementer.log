  --font-instrument: 'JetBrains Mono', ui-monospace, 'SF Mono', 'Menlo', monospace;
}

:root {
  --surface-primary:   var(--paper-100);
  --surface-card:      var(--paper-50);
  --surface-inset:     var(--paper-200);
  --surface-overlay:   rgba(253,251,248,0.92);
  --surface-glass:     rgba(253,251,248,0.72);
  --surface-scrim:     rgba(34,24,16,0.35);
  --content-primary:   var(--ink-900);
