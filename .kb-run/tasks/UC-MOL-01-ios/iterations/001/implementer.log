+        ZStack(alignment: .bottomLeading) {
+            RoundedRectangle(cornerRadius: Theme.shared.radius.md, style: .continuous)
+                .fill(LaneShadowTheme.color.surface.glass)
+                .frame(height: Theme.shared.space.xxxxl + Theme.shared.space.md)
