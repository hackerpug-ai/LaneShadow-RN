/* ─── DOCUMENT CHROME ──────────────────────────────────────────────── */
body {
  font-family: var(--font-ui);
  color: var(--content-primary);
  background: var(--surface-primary);
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
  line-height: 1.55;
  overflow-x: hidden;
}
.wrap { max-width: 1440px; margin: 0 auto; padding: 0 72px; }

.doc-header {
  position: relative;
  padding: 96px 0 72px;
  border-bottom: 1px solid var(--border-default);
  overflow: hidden;
}
.doc-header::before {
  content: "";
  position: absolute; inset: 0;
  background-image:
    radial-gradient(circle at 8% 80%, rgba(238,124,43,0.08), transparent 44%),
    radial-gradient(circle at 92% 12%, rgba(184,90,44,0.05), transparent 50%);
  pointer-events: none;
}
.doc-header > * { position: relative; z-index: 1; }
.doc-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--font-ui); font-size: 10.5px; font-weight: 600;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--signal-default); margin-bottom: 28px;
}
.doc-eyebrow::before { content: ""; width: 28px; height: 1px; background: var(--signal-default); }
.doc-eyebrow-pill {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 999px;
  border: 1px solid var(--signal-default);
  color: var(--signal-default); background: var(--signal-whisper);
  font-size: 9.5px; letter-spacing: 0.14em;
}
.doc-title {
  font-family: var(--font-opinion); font-size: 104px; font-weight: 300;
  line-height: 0.94; letter-spacing: -0.035em;
  color: var(--content-primary); margin-bottom: 32px; max-width: 1000px;
}
.doc-title em { font-style: italic; color: var(--signal-default); font-weight: 400; }
.doc-tagline {
  font-family: var(--font-opinion); font-style: italic;
  font-size: 22px; font-weight: 300;
  color: var(--content-secondary); max-width: 640px; line-height: 1.55; margin-bottom: 56px;
}
.doc-meta-row {
  display: grid; grid-template-columns: repeat(6, 1fr); gap: 24px;
  padding-top: 36px; border-top: 1px solid var(--border-default);
}
.meta-item { display: flex; flex-direction: column; gap: 6px; }
.meta-label { font-family: var(--font-ui); font-size: 9px; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: var(--content-tertiary); }
.meta-value { font-family: var(--font-instrument); font-size: 13px; font-weight: 500; color: var(--content-primary); }

.section { padding: 96px 0; border-bottom: 1px solid var(--border-default); position: relative; }
.section:last-of-type { border-bottom: none; }
.section-header { display: grid; grid-template-columns: 120px 1fr; align-items: baseline; gap: 32px; margin-bottom: 56px; }
.section-index {
  font-family: var(--font-instrument); font-size: 11px; font-weight: 500;
  letter-spacing: 0.14em; color: var(--signal-default); text-transform: uppercase;
  display: flex; align-items: center; gap: 10px;
}
.section-index::before { content: ""; display: block; width: 48px; height: 1px; background: var(--signal-default); }
.section-title {
  font-family: var(--font-opinion); font-size: 52px; font-weight: 300;
  letter-spacing: -0.025em; line-height: 1.04;
  color: var(--content-primary); max-width: 900px;
}
.section-title em { font-style: italic; color: var(--signal-default); font-weight: 400; }
.prose {
  font-family: var(--font-opinion); font-weight: 300; font-size: 19px; line-height: 1.68;
  color: var(--content-secondary); max-width: 720px; margin-left: 152px;
}
.prose + .prose { margin-top: 20px; }
.prose em { font-style: italic; }
.prose strong {
  font-family: var(--font-ui); font-size: 12px; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--signal-default);
  display: inline-block; padding: 2px 8px;
  background: var(--signal-whisper); border: 1px solid var(--signal-tint);
  border-radius: 4px; margin: 0 2px;
}

/* ── LAYOUT HELPERS ─────────────────────────────────────────────────── */
.demo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 40px;
  padding-left: 152px;
  align-items: start;
}
.demo-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
.demo-grid.cols-4 { grid-template-columns: repeat(4, 1fr); }
.demo-cell { display: flex; flex-direction: column; gap: 16px; }
.cell-label {
  font-family: var(--font-instrument); font-size: 10px; font-weight: 500;
  letter-spacing: 0.16em; text-transform: uppercase; color: var(--signal-default);
}
.cell-desc {
  font-family: var(--font-ui); font-size: 11px; color: var(--content-tertiary);
  line-height: 1.5;
}
.annotation-row {
  display: flex; align-items: baseline; gap: 8px; margin-top: 4px;
}
.ann-token {
  font-family: var(--font-instrument); font-size: 9.5px; color: var(--content-tertiary);
  background: var(--surface-inset); border-radius: 3px; padding: 1px 5px;
}
.ann-val {
  font-family: var(--font-instrument); font-size: 9.5px; color: var(--signal-default);
}

/* ── DIMENSIONS TABLE ───────────────────────────────────────────────── */
.dim-table {
  width: 100%; border-collapse: collapse; margin-left: 152px;
  font-family: var(--font-ui); font-size: 12px;
}
.dim-table th {
  font-weight: 600; font-size: 9.5px; letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--content-tertiary); padding: 10px 16px; text-align: left;
  border-bottom: 1px solid var(--border-default);
}
.dim-table td {
  padding: 10px 16px; border-bottom: 1px solid var(--border-subtle);
  color: var(--content-primary); vertical-align: top;
}
.dim-table tr:last-child td { border-bottom: none; }
.dim-table .token { font-family: var(--font-instrument); font-size: 10.5px; color: var(--signal-default); }
.dim-table .val   { font-family: var(--font-instrument); font-size: 10.5px; color: var(--content-secondary); }

/* ── AC CITE ────────────────────────────────────────────────────────── */
.ac-block {
  margin-left: 152px;
  display: flex; flex-direction: column; gap: 10px;
}
.ac-cite {
  font-family: var(--font-ui); font-size: 10.5px; line-height: 1.55;
  color: var(--content-tertiary); padding-left: 20px; position: relative;
}
.ac-cite::before {
  content: "☐"; position: absolute; left: 0; top: 0; color: var(--border-strong);
}

/* ── FOOTER ─────────────────────────────────────────────────────────── */
.doc-footer {
  padding: 64px 0 80px;
  display: flex; align-items: center; justify-content: space-between;
}
.footer-wordmark {
  font-family: var(--font-opinion); font-size: 28px; font-weight: 300;
  letter-spacing: -0.02em; color: var(--content-primary);
}
.footer-wordmark em { font-style: italic; color: var(--signal-default); }

