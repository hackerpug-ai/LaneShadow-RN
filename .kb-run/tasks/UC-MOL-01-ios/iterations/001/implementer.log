diff --git a/ios/LaneShadow/Sandbox/Stories/Molecules/LSContentCardStory.swift b/ios/LaneShadow/Sandbox/Stories/Molecules/LSContentCardStory.swift
new file mode 100644
index 0000000000000000000000000000000000000000..ed2d08ac43b3fff9e664013c726ce431963b9795
--- /dev/null
