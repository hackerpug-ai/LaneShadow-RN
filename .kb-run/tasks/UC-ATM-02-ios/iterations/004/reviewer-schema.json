{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "confidence",
    "summary",
    "tasks",
    "findings",
    "validation"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["APPROVED", "NEEDS_FIXES"]
    },
    "confidence": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "summary": {
      "type": "string"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "verdict", "requirements"],
        "properties": {
          "id": {
            "type": "string",
            "const": "UC-ATM-02-ios"
          },
          "verdict": {
            "type": "string",
            "enum": ["APPROVED", "NEEDS_FIXES"]
          },
          "requirements": {
            "type": "array",
            "minItems": 9,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "satisfied", "evidence", "remediation"],
              "properties": {
                "id": {
                  "type": "string"
                },
                "satisfied": {
                  "type": "boolean"
                },
                "evidence": {
                  "type": "string"
                },
                "remediation": {
                  "type": ["string", "null"]
                }
              }
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "task_id", "location", "evidence", "fix"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"]
          },
          "task_id": {
            "type": "string",
            "const": "UC-ATM-02-ios"
          },
          "location": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "diff_files",
        "scope_check",
        "grep_gates",
        "swiftformat",
        "build",
        "tests",
        "git_status"
      ],
      "properties": {
        "diff_files": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scope_check": {
          "type": "string"
        },
        "grep_gates": {
          "type": "string"
        },
        "swiftformat": {
          "type": "string"
        },
        "build": {
          "type": "string"
        },
        "tests": {
          "type": "string"
        },
        "git_status": {
          "type": "string"
        }
      }
    }
  }
}
