<!DOCTYPE html>
<!-- list-row.html — Molecule · LSListRow
     LaneShadow V2 Copper · Authority: uc-mol-01-card-listrow.html
     Class prefix: .mol-list-row -->
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1200">
<title>Molecule · list-row — LaneShadow V2 Copper</title>
<link rel="stylesheet" href="../../typography/fonts.css">
<link rel="stylesheet" href="../../tokens/tokens.css">
<link rel="stylesheet" href="../../typography/type-modules.css">
<link rel="stylesheet" href="../../atoms/_preview.css">
<link rel="stylesheet" href="../_atoms.css">
<style>

/* ─── MOL-LIST-ROW ───────────────────────────────────────────────────────
   Composes ls-avatar (UC-ATM-04) · ls-icon (UC-ATM-10) · ls-toggle (NEW)
   · ls-btn (UC-ATM-02)
   Single horizontal row: [leading] [content] [trailing]
   ───────────────────────────────────────────────────────────────────────── */

/* ── Row container ─────────────────────────────────────────────────────── */
.mol-list-row {
  display: flex;
  align-items: center;
  min-height: var(--size-touch-min);   /* 44px touch target */
  padding: var(--space-2) var(--space-4);
  gap: var(--space-3);
  background: var(--surface-card);
  cursor: pointer;
  transition: background var(--duration-fast) var(--ease-standard);
  position: relative;
}

/* Separator between sibling rows */
.mol-list-row + .mol-list-row {
  border-top: var(--stroke-sm) solid var(--border-subtle);
}

/* ── States ────────────────────────────────────────────────────────────── */
.mol-list-row.is-hover {
  background: var(--surface-inset);
}

.mol-list-row.is-pressed {
  background: var(--surface-inset);
}

.mol-list-row.is-focused {
  outline: var(--stroke-md) solid var(--border-focus);
  outline-offset: -2px;
  border-radius: var(--radius-sm);
}

.mol-list-row.is-disabled {
  opacity: var(--opacity-disabled);
  pointer-events: none;
  cursor: not-allowed;
}

/* Non-interactive variant — no hover, default cursor */
.mol-list-row--non-interactive {
  cursor: default;
}

.mol-list-row--non-interactive.is-hover {
  background: var(--surface-card);
}

/* ── Leading slot ──────────────────────────────────────────────────────── */
.mol-list-row__leading {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Icon container: 32×32 tinted badge */
.mol-list-row__icon-container {
  width: var(--space-8);   /* 32px */
  height: var(--space-8);  /* 32px */
  border-radius: var(--radius-sm);
  background: var(--surface-inset);
  border: var(--stroke-sm) solid var(--border-default);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--content-secondary);
}

/* ── Content (title + subtitle) ────────────────────────────────────────── */
.mol-list-row__content {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
}

.mol-list-row__title {
  color: var(--content-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mol-list-row__subtitle {
  color: var(--content-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Trailing slot ─────────────────────────────────────────────────────── */
.mol-list-row__trailing {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: var(--space-3);
  color: var(--content-tertiary);
}

/* Trailing status label (e.g. "Locked") */
.mol-list-row__trailing-label {
  color: var(--content-subtle);
}

/* Chevron icon */
.mol-list-row__chevron {
  color: var(--content-subtle);
  flex-shrink: 0;
}

/* ── Toggle (ls-toggle atom) ───────────────────────────────────────────── */
/* ls-toggle styles live in _atoms.css once the atom is registered.
   Molecule only positions it — no redefinition of .ls-toggle here. */

/* ── Group wrapper — rows inside ls-card ───────────────────────────────── */
.mol-list-group {
  overflow: hidden;
  border-radius: var(--radius-lg);
  border: var(--stroke-sm) solid var(--border-default);
  box-shadow: var(--elev-card);
  background: var(--surface-card);
}

.mol-list-group .mol-list-row:first-child {
  border-top: none;
}

/* ── Group header label ────────────────────────────────────────────────── */
.mol-list-group__header {
  padding: var(--space-4) var(--space-4) var(--space-3);
  border-bottom: var(--stroke-sm) solid var(--border-subtle);
  color: var(--content-tertiary);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

</style>
</head>
