+import com.nativesandbox.model.Story
+
+object LSListRowStory {
+    val all: List<Story> = listOf(
+        story(
+            id = "molecules.listrow.leadingIcon",
+            name = "Leading Icon",
+            summary = "Row with icon-leading content.",
+        ) {
