+                trailing = LSListRowTrailing.Button(label = "Follow"),
+            )
+        },
+    )
+}
+
+private fun story(
+    id: String,
+    name: String,
+    summary: String,
+    content: @Composable () -> Unit,
+): Story =
+    Story(
+        id = id,
+        tier = ComponentTier.Molecule,
+        component = "LSListRow",
+        name = name,
+        summary = summary,
+        content = { MoleculeStoryFrame(content) },
+    )
