+}
+
+private fun story(
+    id: String,
+    name: String,
+    summary: String,
+    content: @Composable () -> Unit,
+): Story =
+    Story(
+        id = id,
+        tier = ComponentTier.Molecule,
+        component = "LSContentCard",
+        name = name,
+        summary = summary,
+        content = { MoleculeStoryFrame(content) },
+    )
