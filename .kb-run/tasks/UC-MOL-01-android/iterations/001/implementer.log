<style>

/* ─── MOL-CONTENT-CARD ───────────────────────────────────────────────────
   Composes ls-card (UC-ATM-05) · ls-pill (UC-ATM-07) · ls-btn (UC-ATM-02)
   Slot schema: [image-header?] body[title, subtitle?, meta?, chips?] [footer?]
   ───────────────────────────────────────────────────────────────────────── */

.mol-content-card {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  width: 100%;
}

/* ── Image header slot ─────────────────────────────────────────────────── */
.mol-content-card__image-header {
  width: 100%;
  height: 120px;
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
  background: var(--surface-inset);
}

/* Gradient overlay for image label legibility */
.mol-content-card__image-header::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 40%,
    var(--surface-scrim) 100%
  );
  pointer-events: none;
}

/* Placeholder fill — renders behind real img */
.mol-content-card__image-fill {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    var(--signal-whisper) 0%,
    var(--border-default) 100%
  );
}

.mol-content-card__image-label {
  position: absolute;
  bottom: var(--space-3);
  left: var(--space-4);
  z-index: 1;
  color: var(--content-on-signal);
  opacity: var(--opacity-dim);
}

/* ── Body ──────────────────────────────────────────────────────────────── */
.mol-content-card__body {
  padding: var(--space-4);
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
}

/* ── Title row ─────────────────────────────────────────────────────────── */
.mol-content-card__title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-3);
}

.mol-content-card__title {
  color: var(--content-primary);
  flex: 1;
  min-width: 0;
}

/* ── Subtitle ──────────────────────────────────────────────────────────── */
.mol-content-card__subtitle {
  color: var(--content-secondary);
}

/* ── Meta row (instrument/mono stat items) ─────────────────────────────── */
.mol-content-card__meta {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  flex-wrap: wrap;
}

.mol-content-card__meta-item {
  color: var(--content-tertiary);
}

.mol-content-card__meta-dot {
  width: var(--space-1);
  height: var(--space-1);
  border-radius: var(--radius-pill);
  background: var(--border-strong);
  flex-shrink: 0;
}

/* ── Chip row ──────────────────────────────────────────────────────────── */
.mol-content-card__chip-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

/* Chip: inline label pill — neutral or signal */
.mol-content-card__chip {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  border-radius: var(--radius-pill);
  border: var(--stroke-sm) solid var(--border-default);
  background: var(--surface-inset);
  color: var(--content-secondary);
  white-space: nowrap;
}

.mol-content-card__chip--signal {
  background: var(--signal-whisper);
  border-color: var(--signal-tint);
  color: var(--signal-default);
}

/* ── Actions footer ────────────────────────────────────────────────────── */
.mol-content-card__footer {
  padding: var(--space-3) var(--space-4);
  border-top: var(--stroke-sm) solid var(--border-subtle);
  background: var(--surface-inset);
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

/* ── States — hover/pressed on interactive cards ──────────────────────── */
.mol-content-card--interactive {
  cursor: pointer;
  transition:
    box-shadow var(--duration-fast) var(--ease-standard),
    transform var(--duration-fast) var(--ease-standard);
}

.mol-content-card--interactive.is-hover {
  box-shadow: var(--elev-overlay);
}

.mol-content-card--interactive.is-pressed {
  transform: translateY(1px);
  box-shadow: var(--elev-card);
}

.mol-content-card--interactive.is-disabled {
  opacity: var(--opacity-disabled);
  pointer-events: none;
  cursor: not-allowed;
}

</style>
</head>
<body>

<header class="preview-header">
  <h1>Molecule · <em>content-card</em></h1>
  <p class="subtitle">LSContentCard — structured card with title, optional image, chips, and action footer · Authority: uc-mol-01-card-listrow.html</p>
</header>

