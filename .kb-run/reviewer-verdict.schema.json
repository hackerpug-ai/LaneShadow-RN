{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "verdict",
    "confidence",
    "tasks",
    "findings",
    "summary"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVED",
        "NEEDS_FIXES"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "verdict",
          "requirements"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "APPROVED",
              "NEEDS_FIXES"
            ]
          },
          "requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "satisfied",
                "evidence",
                "remediation"
              ],
              "properties": {
                "id": {
                  "type": "string"
                },
                "satisfied": {
                  "type": "boolean"
                },
                "evidence": {
                  "type": "string"
                },
                "remediation": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "task_id",
          "location",
          "evidence",
          "fix"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "CRITICAL",
              "HIGH",
              "MEDIUM",
              "LOW"
            ]
          },
          "task_id": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}
