{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "task_id",
    "blocking_issues",
    "unblock_options",
    "failure_classification",
    "failed_commands",
    "evidence_path",
    "evidence_manifest_path",
    "summary",
    "files_changed",
    "verification_commands",
    "acceptance_criteria_evidence",
    "reviewer_considerations",
    "notes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "blocked"
      ]
    },
    "task_id": {
      "type": "string"
    },
    "blocking_issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unblock_options": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_classification": {
      "type": "string",
      "enum": [
        "none",
        "pre_existing",
        "task_introduced"
      ]
    },
    "failed_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "evidence_path": {
      "type": "string"
    },
    "evidence_manifest_path": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verification_commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "met",
              "not_met"
            ]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "reviewer_considerations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
