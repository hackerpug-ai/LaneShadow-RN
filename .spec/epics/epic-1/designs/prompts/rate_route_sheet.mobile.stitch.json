{
  "design_key": "rate_route_sheet",
  "device": "mobile",
  "screen": "Rate Route Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Phase 3: Rate and add notes to a completed ride",
  "phase": 3,
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "surface_elevated": "#36302b",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "bottom_partial",
    "height": "60vh",
    "background": "#1A1C1F",
    "border_radius_top": "32px",
    "shadow": "0 -8px 30px rgba(0,0,0,0.5)"
  },
  "header": {
    "drag_handle": {
      "width": "36px",
      "height": "4px",
      "background": "rgba(255,255,255,0.2)",
      "border_radius": "2px",
      "margin_top": "8px"
    },
    "title": {
      "text": "How was your ride?",
      "style": "20px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "form",
    "padding": "24px",
    "sections": [
      {
        "id": "route_summary",
        "type": "summary_card",
        "background": "#24272B",
        "border_radius": "12px",
        "padding": "16px",
        "margin_bottom": "24px",
        "layout": "horizontal",
        "gap": "12px",
        "content": {
          "thumbnail": {
            "size": "60x60",
            "border_radius": "8px"
          },
          "details": {
            "name": "Scenic Coast Route",
            "subtitle": "87 mi 2h 15m"
          }
        }
      },
      {
        "id": "star_rating",
        "type": "star_rating_input",
        "label": "Rate this ride",
        "label_style": "14px 600 rgba(255,255,255,0.72)",
        "margin_bottom": "24px",
        "size": "40px",
        "gap": "8px",
        "active_color": "#fbbf24",
        "inactive_color": "rgba(255,255,255,0.2)",
        "value": 0,
        "required": true
      },
      {
        "id": "notes_input",
        "type": "text_area",
        "label": "Notes (optional)",
        "placeholder": "How did the ride go? Any highlights or issues?",
        "background": "#36302b",
        "height": "100px",
        "border_radius": "12px",
        "margin_bottom": "16px",
        "max_length": 2000
      },
      {
        "id": "tags_picker",
        "type": "tag_picker",
        "label": "Tags (optional)",
        "label_style": "14px 600 rgba(255,255,255,0.72)",
        "max_tags": 10,
        "suggested_tags": [
          "Great scenery",
          "Smooth roads",
          "Light traffic",
          "Heavy traffic",
          "Weather issues",
          "Would repeat",
          "Construction",
          "Favorite segment"
        ],
        "tag_style": {
          "background": "#24272B",
          "border_radius": "16px",
          "padding": "8px 12px"
        }
      }
    ]
  },
  "actions": {
    "padding": "24px",
    "items": [
      {
        "label": "Save Rating",
        "style": "primary",
        "height": "56px",
        "background": "#B87333",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true,
        "disabled_until": "rating_selected"
      }
    ]
  },
  "validation": {
    "stars": "1-5 required",
    "notes": "max 2000 characters",
    "tags": "max 10 tags"
  },
  "states": {
    "default": "Rating form displayed",
    "saving": "Save button shows spinner"
  }
}
