{
  "design_key": "confirm_delete_route_sheet",
  "device": "mobile",
  "screen": "Confirm Delete Route Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Modal confirmation for permanent route deletion",
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "primary": "#B87333",
    "error": "#E35D6A",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "modal",
    "background": "#1A1C1F",
    "border_radius": "24px",
    "margin": "24px",
    "shadow": "0 8px 30px rgba(0,0,0,0.5)",
    "scrim": "rgba(0,0,0,0.55)",
    "backdrop_blur": "8px"
  },
  "header": {
    "padding": "24px",
    "title": {
      "text": "Delete Route?",
      "style": "20px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "vertical",
    "padding": "0 24px",
    "sections": [
      {
        "id": "warning_card",
        "type": "card",
        "background": "rgba(227,93,106,0.1)",
        "border": "1px solid rgba(227,93,106,0.3)",
        "border_radius": "12px",
        "padding": "16px",
        "margin_bottom": "16px",
        "content": {
          "icon": "warning",
          "icon_color": "#E35D6A",
          "icon_size": "24px",
          "text": "This action cannot be undone. The route and all its data will be permanently deleted.",
          "text_style": "14px 400 rgba(255,255,255,0.72)"
        }
      },
      {
        "id": "route_preview",
        "type": "preview_card",
        "background": "#24272B",
        "border_radius": "12px",
        "padding": "16px",
        "layout": "horizontal",
        "gap": "12px",
        "content": {
          "thumbnail": {
            "size": "64x64",
            "border_radius": "8px"
          },
          "details": {
            "name": "Scenic Coast Route",
            "name_style": "16px 500 rgba(255,255,255,0.92)",
            "subtitle": "87 mi 2h 15m",
            "subtitle_style": "14px 400 rgba(255,255,255,0.55)"
          }
        }
      }
    ]
  },
  "actions": {
    "padding": "24px",
    "gap": "12px",
    "items": [
      {
        "label": "Delete Route",
        "style": "destructive",
        "height": "56px",
        "background": "#E35D6A",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true,
        "icon": "delete",
        "shadow": "0 4px 12px rgba(227,93,106,0.3)"
      },
      {
        "label": "Cancel",
        "style": "text",
        "height": "48px",
        "text_color": "rgba(255,255,255,0.55)",
        "font": "16px 400"
      }
    ]
  },
  "states": {
    "default": "Confirmation dialog displayed",
    "deleting": "Delete button shows spinner",
    "error": "Error message displayed"
  }
}
