{
  "design_key": "legal_about",
  "device": "mobile",
  "screen": "Legal About (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "About and legal information screen",
  "theme": {
    "background": "#0E0F11",
    "surface": "#1A1C1F",
    "surface_elevated": "#24272B",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "header": {
    "type": "standard",
    "background": "#0E0F11",
    "back_arrow": true,
    "title": {
      "text": "About",
      "style": "24px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "scrollable",
    "padding": "24px",
    "sections": [
      {
        "id": "app_info",
        "type": "centered_content",
        "margin_bottom": "32px",
        "content": {
          "logo": {
            "size": "80px",
            "margin_bottom": "16px"
          },
          "name": {
            "text": "LaneShadow",
            "style": "24px 600 rgba(255,255,255,0.92)",
            "font_family": "Space Grotesk"
          },
          "version": {
            "text": "Version 1.0.0",
            "style": "14px 400 rgba(255,255,255,0.55)",
            "margin_top": "4px"
          },
          "tagline": {
            "text": "Plan scenic rides with confidence",
            "style": "14px 400 rgba(255,255,255,0.72)",
            "margin_top": "8px"
          }
        }
      },
      {
        "id": "legal_links",
        "type": "link_list",
        "background": "#24272B",
        "border_radius": "16px",
        "items": [
          {
            "label": "Terms of Service",
            "icon": "description",
            "chevron": true,
            "action": "open_external_url"
          },
          {
            "label": "Privacy Policy",
            "icon": "privacy_tip",
            "chevron": true,
            "action": "open_external_url"
          },
          {
            "label": "Open Source Licenses",
            "icon": "code",
            "chevron": true,
            "action": "navigate_licenses"
          }
        ]
      },
      {
        "id": "credits",
        "type": "text_block",
        "margin_top": "24px",
        "padding": "16px",
        "background": "#24272B",
        "border_radius": "16px",
        "content": {
          "title": "Credits",
          "title_style": "14px 600 rgba(255,255,255,0.72)",
          "body": "Map data OpenStreetMap contributors\nWeather data Open-Meteo\nRouting OSRM",
          "body_style": "14px 400 rgba(255,255,255,0.55)"
        }
      }
    ]
  },
  "footer": {
    "position": "bottom",
    "padding": "24px",
    "content": {
      "type": "text",
      "text": "Made with passion for riders",
      "style": "12px 400 rgba(255,255,255,0.35)",
      "align": "center"
    }
  },
  "states": {
    "default": "About info displayed"
  }
}
