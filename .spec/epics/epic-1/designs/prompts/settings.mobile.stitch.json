{
  "design_key": "settings",
  "device": "mobile",
  "screen": "Settings (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Minimal POC settings screen with units and account options",
  "theme": {
    "background": "#0E0F11",
    "surface": "#1A1C1F",
    "surface_elevated": "#24272B",
    "primary": "#B87333",
    "error": "#E35D6A",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "header": {
    "type": "standard",
    "background": "#0E0F11",
    "title": {
      "text": "Settings",
      "style": "24px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "section_list",
    "padding": "16px",
    "sections": [
      {
        "id": "units_section",
        "type": "section",
        "label": "UNITS",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "margin_bottom": "24px",
        "content": {
          "background": "#24272B",
          "border_radius": "16px",
          "items": [
            {
              "type": "setting_row",
              "label": "Temperature",
              "control": {
                "type": "segmented_control",
                "options": ["°F", "°C"],
                "selected": 0
              }
            },
            {
              "type": "setting_row",
              "label": "Distance",
              "control": {
                "type": "segmented_control",
                "options": ["Miles", "Km"],
                "selected": 0
              }
            }
          ]
        }
      },
      {
        "id": "account_section",
        "type": "section",
        "label": "ACCOUNT",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "margin_bottom": "24px",
        "content": {
          "background": "#24272B",
          "border_radius": "16px",
          "items": [
            {
              "type": "setting_row",
              "label": "Email",
              "value": "rider@example.com",
              "chevron": false
            },
            {
              "type": "setting_row",
              "label": "Sign Out",
              "text_color": "#E35D6A",
              "chevron": false,
              "action": "sign_out"
            }
          ]
        }
      },
      {
        "id": "about_section",
        "type": "section",
        "label": "ABOUT",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "content": {
          "background": "#24272B",
          "border_radius": "16px",
          "items": [
            {
              "type": "setting_row",
              "label": "About LaneShadow",
              "chevron": true,
              "action": "navigate_about"
            },
            {
              "type": "setting_row",
              "label": "Terms of Service",
              "chevron": true,
              "action": "open_url"
            },
            {
              "type": "setting_row",
              "label": "Privacy Policy",
              "chevron": true,
              "action": "open_url"
            }
          ]
        }
      }
    ]
  },
  "footer": {
    "position": "bottom",
    "padding": "24px",
    "content": {
      "type": "text",
      "text": "Version 1.0.0 (Build 1)",
      "style": "12px 400 rgba(255,255,255,0.35)",
      "align": "center"
    }
  },
  "components": {
    "setting_row": {
      "height": "56px",
      "padding": "0 16px",
      "layout": "row",
      "justify": "space-between",
      "align": "center",
      "border_bottom": "1px solid rgba(255,255,255,0.08)"
    }
  },
  "states": {
    "default": "Settings list displayed"
  }
}
