{
  "design_key": "preferences_screen",
  "device": "mobile",
  "screen": "Preferences Screen (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Phase 2: Manage default route generation preferences",
  "phase": 2,
  "theme": {
    "background": "#0E0F11",
    "surface": "#1A1C1F",
    "surface_elevated": "#24272B",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "header": {
    "type": "standard",
    "background": "#0E0F11",
    "title": {
      "text": "Route Preferences",
      "style": "24px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "section_list",
    "padding": "16px",
    "sections": [
      {
        "id": "default_style",
        "type": "section",
        "label": "DEFAULT ROUTE STYLE",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "margin_bottom": "24px",
        "content": {
          "type": "segmented_control",
          "background": "#36302b",
          "border_radius": "12px",
          "padding": "4px",
          "options": [
            { "label": "Direct", "value": "direct" },
            { "label": "Balanced", "value": "balanced", "selected": true },
            { "label": "Scenic", "value": "scenic" }
          ]
        }
      },
      {
        "id": "avoid_preferences",
        "type": "section",
        "label": "AVOID BY DEFAULT",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "margin_bottom": "24px",
        "content": {
          "background": "#24272B",
          "border_radius": "16px",
          "items": [
            {
              "type": "toggle_row",
              "icon": "remove_road",
              "label": "Highways",
              "value": false
            },
            {
              "type": "toggle_row",
              "icon": "toll",
              "label": "Toll Roads",
              "value": false
            }
          ]
        }
      },
      {
        "id": "personalization",
        "type": "section",
        "label": "PERSONALIZATION",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "content": {
          "background": "#24272B",
          "border_radius": "16px",
          "items": [
            {
              "type": "nav_row",
              "icon": "block",
              "label": "Avoid Areas",
              "subtitle": "3 areas defined",
              "chevron": true,
              "action": "navigate_avoid_areas"
            },
            {
              "type": "nav_row",
              "icon": "favorite",
              "label": "Favorite Roads",
              "subtitle": "7 saved segments",
              "chevron": true,
              "action": "navigate_favorite_roads"
            }
          ]
        }
      }
    ]
  },
  "navigation": {
    "type": "bottom_tabs",
    "background": "#1A1C1F",
    "height": "64px",
    "active_color": "#B87333",
    "inactive_color": "rgba(255,255,255,0.55)",
    "tabs": [
      { "label": "Explore", "icon": "map", "active": false },
      { "label": "Saved", "icon": "bookmark", "active": false },
      { "label": "Rides", "icon": "two_wheeler", "active": false },
      { "label": "Profile", "icon": "person", "active": true }
    ]
  },
  "states": {
    "default": "Preferences displayed",
    "saving": "Auto-save in progress"
  }
}
