{
  "design_key": "saved_routes_list",
  "device": "mobile",
  "screen": "Saved Routes List (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "List of saved routes with search, map thumbnails, and route stats",
  "theme": {
    "background": "#0E0F11",
    "surface": "#1A1C1F",
    "surface_elevated": "#24272B",
    "primary": "#B87333",
    "warning": "#D98E04",
    "error": "#E35D6A",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "header": {
    "type": "standard",
    "background": "#0E0F11",
    "title": {
      "text": "Saved Routes",
      "style": "24px 600 rgba(255,255,255,0.92)"
    },
    "trailing_action": {
      "label": "Edit",
      "color": "#B87333"
    }
  },
  "layout": {
    "type": "scrollable_list",
    "padding": "16px",
    "sections": [
      {
        "id": "search_bar",
        "type": "search_input",
        "background": "#24272B",
        "border_radius": "12px",
        "placeholder": "Search routes...",
        "leading_icon": "search",
        "margin_bottom": "16px"
      },
      {
        "id": "route_list",
        "type": "card_list",
        "gap": "12px",
        "content": "List of SavedRouteCard components"
      }
    ]
  },
  "components": {
    "saved_route_card": {
      "background": "#24272B",
      "border": "1px solid rgba(255,255,255,0.05)",
      "border_radius": "16px",
      "padding": "16px",
      "layout": "horizontal",
      "children": [
        {
          "id": "thumbnail",
          "type": "map_thumbnail",
          "size": "96x96",
          "border_radius": "12px",
          "content": "Static map image with route polyline"
        },
        {
          "id": "details",
          "type": "column",
          "flex": 1,
          "margin_left": "12px",
          "children": [
            { "type": "text", "style": "16px 600 text_primary", "content": "Route Name" },
            { "type": "text", "style": "14px 400 text_secondary", "content": "Start → End" },
            {
              "type": "row",
              "margin_top": "8px",
              "gap": "12px",
              "children": [
                { "type": "stat", "icon": "schedule", "value": "2h 15m" },
                { "type": "stat", "icon": "distance", "value": "87 mi" }
              ]
            }
          ]
        },
        {
          "id": "chevron",
          "type": "icon",
          "icon": "chevron_right",
          "color": "text_muted"
        }
      ]
    }
  },
  "fab": {
    "position": { "right": "16px", "bottom": "100px" },
    "background": "#B87333",
    "shadow": "0 8px 16px rgba(184,115,50,0.4)",
    "icon": "add",
    "action": "Open Plan Ride Sheet"
  },
  "navigation": {
    "type": "bottom_tabs",
    "background": "#1A1C1F",
    "border_top": "1px solid rgba(255,255,255,0.08)",
    "height": "64px",
    "active_color": "#B87333",
    "inactive_color": "rgba(255,255,255,0.55)",
    "tabs": [
      { "label": "Explore", "icon": "map", "active": false },
      { "label": "Saved", "icon": "bookmark", "active": true },
      { "label": "Rides", "icon": "two_wheeler", "active": false },
      { "label": "Profile", "icon": "person", "active": false }
    ]
  },
  "states": {
    "default": "List with route cards",
    "empty": "EmptyState component with illustration",
    "search_active": "Filtered results based on search query",
    "edit_mode": "Multi-select checkboxes visible"
  }
}
