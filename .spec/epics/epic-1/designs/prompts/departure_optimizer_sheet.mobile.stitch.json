{
  "design_key": "departure_optimizer_sheet",
  "device": "mobile",
  "screen": "Departure Optimizer Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Phase 3: View optimal departure time windows based on weather",
  "phase": 3,
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "surface_elevated": "#36302b",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "bottom_partial",
    "height": "70vh",
    "background": "#1A1C1F",
    "border_radius_top": "32px",
    "shadow": "0 -8px 30px rgba(0,0,0,0.5)"
  },
  "header": {
    "drag_handle": {
      "width": "36px",
      "height": "4px",
      "background": "rgba(255,255,255,0.2)",
      "border_radius": "2px",
      "margin_top": "8px"
    },
    "title": {
      "text": "Best Time to Ride",
      "style": "20px 600 rgba(255,255,255,0.92)"
    },
    "date_selector": {
      "type": "horizontal_scroll",
      "margin_top": "16px",
      "items": [
        { "label": "Today", "date": "Jan 29", "selected": true },
        { "label": "Tomorrow", "date": "Jan 30" },
        { "label": "Thu", "date": "Jan 31" },
        { "label": "Fri", "date": "Feb 1" }
      ],
      "item_style": {
        "background": "#24272B",
        "selected_background": "#B87333",
        "border_radius": "12px",
        "padding": "12px 16px"
      }
    }
  },
  "layout": {
    "type": "scrollable",
    "padding": "24px",
    "sections": [
      {
        "id": "optimal_window_card",
        "type": "featured_card",
        "background": "rgba(74,222,128,0.1)",
        "border": "1px solid rgba(74,222,128,0.3)",
        "border_radius": "16px",
        "padding": "20px",
        "margin_bottom": "20px",
        "content": {
          "badge": {
            "label": "Recommended",
            "background": "rgba(74,222,128,0.2)",
            "text_color": "#4ade80",
            "icon": "thumb_up"
          },
          "time_range": {
            "text": "6:00 AM - 9:00 AM",
            "style": "24px 600 rgba(255,255,255,0.92)"
          },
          "score": {
            "value": 92,
            "label": "Conditions Score",
            "bar_color": "#4ade80"
          },
          "reasons": [
            { "icon": "air", "text": "Light winds (5-10 mph)" },
            { "icon": "thermostat", "text": "Comfortable temps (65-72°F)" },
            { "icon": "wb_sunny", "text": "Clear skies" }
          ]
        }
      },
      {
        "id": "windows_list",
        "type": "list",
        "label": "Other Windows",
        "label_style": "14px 600 rgba(255,255,255,0.55) uppercase",
        "gap": "12px",
        "items": "WindowCard components"
      }
    ]
  },
  "components": {
    "window_card": {
      "background": "#24272B",
      "border_radius": "12px",
      "padding": "16px",
      "layout": "horizontal",
      "justify": "space-between",
      "children": [
        {
          "type": "column",
          "children": [
            { "type": "text", "style": "16px 500 text_primary", "content": "10:00 AM - 1:00 PM" },
            {
              "type": "row",
              "gap": "8px",
              "margin_top": "4px",
              "children": [
                { "type": "mini_badge", "icon": "air", "label": "Moderate" },
                { "type": "mini_badge", "icon": "thermostat", "label": "74°F" }
              ]
            }
          ]
        },
        {
          "type": "score_badge",
          "value": 78,
          "color": "#fbbf24"
        }
      ]
    }
  },
  "actions": {
    "padding": "24px",
    "items": [
      {
        "label": "Select This Time",
        "style": "primary",
        "height": "56px",
        "background": "#B87333",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true
      }
    ]
  },
  "states": {
    "default": "Windows displayed for selected date",
    "loading": "Loading weather data",
    "unavailable": "No good windows found"
  }
}
