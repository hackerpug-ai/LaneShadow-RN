{
  "design_key": "planning_error_sheet",
  "device": "mobile",
  "screen": "Planning Error Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Modal displaying planning failures with recovery options",
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "primary": "#B87333",
    "error": "#E35D6A",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "modal",
    "background": "#1A1C1F",
    "border_radius": "24px",
    "margin": "24px",
    "shadow": "0 8px 30px rgba(0,0,0,0.5)",
    "scrim": "rgba(0,0,0,0.55)"
  },
  "header": {
    "padding": "32px 24px 24px",
    "align": "center",
    "icon": {
      "name": "error_outline",
      "size": "64px",
      "color": "#E35D6A",
      "margin_bottom": "16px"
    },
    "title": {
      "text": "Unable to Plan Route",
      "style": "20px 600 rgba(255,255,255,0.92)",
      "align": "center"
    }
  },
  "layout": {
    "type": "vertical",
    "padding": "0 24px",
    "sections": [
      {
        "id": "error_message",
        "type": "text",
        "text": "We couldn't find a route between these locations. This might be due to:",
        "style": "14px 400 rgba(255,255,255,0.72)",
        "align": "center",
        "margin_bottom": "16px"
      },
      {
        "id": "error_reasons",
        "type": "list",
        "background": "#24272B",
        "border_radius": "12px",
        "padding": "16px",
        "gap": "12px",
        "items": [
          { "icon": "location_off", "text": "Locations too far apart" },
          { "icon": "block", "text": "No roads connecting the points" },
          { "icon": "wifi_off", "text": "Network connectivity issues" }
        ],
        "item_style": {
          "icon_size": "20px",
          "icon_color": "rgba(255,255,255,0.55)",
          "text_style": "14px 400 rgba(255,255,255,0.72)"
        }
      }
    ]
  },
  "actions": {
    "padding": "24px",
    "padding_bottom": "32px",
    "gap": "12px",
    "items": [
      {
        "label": "Try Again",
        "style": "primary",
        "height": "56px",
        "background": "#B87333",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true,
        "icon": "refresh"
      },
      {
        "label": "Adjust Locations",
        "style": "secondary",
        "height": "48px",
        "background": "transparent",
        "text_color": "rgba(255,255,255,0.72)",
        "border": "1px solid rgba(255,255,255,0.08)",
        "border_radius": "20px",
        "font": "16px 500",
        "full_width": true,
        "icon": "edit_location"
      },
      {
        "label": "Cancel",
        "style": "text",
        "height": "48px",
        "text_color": "rgba(255,255,255,0.55)",
        "font": "16px 400"
      }
    ]
  },
  "error_codes": {
    "NETWORK_ERROR": {
      "icon": "wifi_off",
      "title": "Connection Error",
      "message": "Unable to connect. Check your connection and try again."
    },
    "ROUTING_NOT_FOUND": {
      "icon": "wrong_location",
      "title": "No Routes Found",
      "message": "No routes found for these locations. Try different points."
    },
    "LLM_SKETCH_INVALID": {
      "icon": "error_outline",
      "title": "Planning Failed",
      "message": "Unable to plan this route. Try different locations."
    },
    "LLM_SKETCH_AMBIGUOUS": {
      "icon": "help_outline",
      "title": "Unclear Route",
      "message": "Route intent unclear. Please be more specific."
    },
    "ROUTING_COMPILE_FAILED": {
      "icon": "error_outline",
      "title": "Route Compilation Failed",
      "message": "Route compilation failed. Please try again."
    },
    "CONDITIONS_LOOKUP_FAILED": {
      "icon": "cloud_off",
      "title": "Weather Unavailable",
      "message": "Weather data unavailable. Route planned without conditions."
    }
  },
  "states": {
    "network_error": "Network/timeout failure display",
    "routing_error": "No routes found display",
    "auth_error": "Session expired display",
    "llm_sketch_invalid": "LLM planning error",
    "conditions_lookup_failed": "Soft-fail for weather"
  }
}
