{
  "design_key": "rain_legend_sheet",
  "device": "mobile",
  "screen": "Rain Legend Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Modal explaining rain probability levels (Sprint 5)",
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "modal",
    "background": "#1A1C1F",
    "border_radius": "24px",
    "margin": "24px",
    "shadow": "0 8px 30px rgba(0,0,0,0.5)",
    "scrim": "rgba(0,0,0,0.55)"
  },
  "header": {
    "padding": "24px",
    "title": {
      "text": "Rain Forecast",
      "style": "20px 600 rgba(255,255,255,0.92)"
    },
    "close_button": {
      "icon": "close",
      "position": "top_right",
      "color": "rgba(255,255,255,0.55)"
    }
  },
  "layout": {
    "type": "vertical",
    "padding": "0 24px 24px",
    "sections": [
      {
        "id": "legend_rows",
        "type": "list",
        "gap": "16px",
        "items": [
          {
            "type": "legend_row",
            "color": "transparent",
            "border": "1px dashed rgba(255,255,255,0.2)",
            "level": "None",
            "range": "0-20%",
            "description": "No rain expected",
            "icon": "wb_sunny"
          },
          {
            "type": "legend_row",
            "color": "#93c5fd",
            "color_name": "blue-300",
            "level": "Light",
            "range": "20-50%",
            "description": "Light rain possible",
            "icon": "grain"
          },
          {
            "type": "legend_row",
            "color": "#3b82f6",
            "color_name": "blue-500",
            "level": "Moderate",
            "range": "50-70%",
            "description": "Rain likely, pack gear",
            "icon": "water_drop"
          },
          {
            "type": "legend_row",
            "color": "#1d4ed8",
            "color_name": "blue-700",
            "level": "Heavy",
            "range": "70%+",
            "description": "Heavy rain expected",
            "icon": "thunderstorm"
          }
        ]
      },
      {
        "id": "time_disclaimer",
        "type": "text",
        "margin_top": "24px",
        "padding": "16px",
        "background": "#24272B",
        "border_radius": "12px",
        "text": "Rain probabilities are based on hourly forecasts for your estimated arrival time at each route segment. Conditions may change.",
        "style": "12px 400 rgba(255,255,255,0.55)"
      }
    ]
  },
  "actions": {
    "padding": "24px",
    "items": [
      {
        "label": "Got it",
        "style": "primary",
        "height": "48px",
        "background": "#B87333",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true
      }
    ]
  },
  "states": {
    "default": "Legend displayed"
  }
}
