{
  "design_key": "temperature_legend_sheet",
  "device": "mobile",
  "screen": "Temperature Legend Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Modal explaining temperature ranges and comfort zones (Sprint 5)",
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "modal",
    "background": "#1A1C1F",
    "border_radius": "24px",
    "margin": "24px",
    "shadow": "0 8px 30px rgba(0,0,0,0.5)",
    "scrim": "rgba(0,0,0,0.55)"
  },
  "header": {
    "padding": "24px",
    "title": {
      "text": "Temperature Guide",
      "style": "20px 600 rgba(255,255,255,0.92)"
    },
    "close_button": {
      "icon": "close",
      "position": "top_right",
      "color": "rgba(255,255,255,0.55)"
    },
    "unit_toggle": {
      "type": "segmented_control",
      "margin_top": "16px",
      "options": ["°F", "°C"],
      "selected": 0,
      "container": {
        "background": "#36302b",
        "border_radius": "8px",
        "padding": "2px"
      }
    }
  },
  "layout": {
    "type": "vertical",
    "padding": "0 24px 24px",
    "sections": [
      {
        "id": "temperature_gradient",
        "type": "gradient_bar",
        "height": "24px",
        "border_radius": "12px",
        "margin_bottom": "24px",
        "gradient": ["#2563eb", "#93c5fd", "#4ade80", "#fb923c", "#ef4444"],
        "labels": {
          "start": "Cold",
          "end": "Hot"
        }
      },
      {
        "id": "comfort_zones",
        "type": "list",
        "gap": "12px",
        "items": [
          {
            "type": "comfort_zone_row",
            "color": "#2563eb",
            "zone": "Cold",
            "range_f": "<50°F",
            "range_c": "<10°C",
            "advice": "Layer up, heated gear recommended",
            "icon": "ac_unit"
          },
          {
            "type": "comfort_zone_row",
            "color": "#93c5fd",
            "zone": "Cool",
            "range_f": "50-65°F",
            "range_c": "10-18°C",
            "advice": "Light jacket weather",
            "icon": "thermostat"
          },
          {
            "type": "comfort_zone_row",
            "color": "#4ade80",
            "zone": "Comfortable",
            "range_f": "65-80°F",
            "range_c": "18-27°C",
            "advice": "Ideal riding conditions",
            "icon": "sentiment_satisfied",
            "highlight": true
          },
          {
            "type": "comfort_zone_row",
            "color": "#fb923c",
            "zone": "Warm",
            "range_f": "80-95°F",
            "range_c": "27-35°C",
            "advice": "Stay hydrated, mesh gear",
            "icon": "wb_sunny"
          },
          {
            "type": "comfort_zone_row",
            "color": "#ef4444",
            "zone": "Hot",
            "range_f": ">95°F",
            "range_c": ">35°C",
            "advice": "Extreme heat, limit exposure",
            "icon": "warning"
          }
        ]
      }
    ]
  },
  "components": {
    "comfort_zone_row": {
      "layout": "horizontal",
      "padding": "12px",
      "background": "#24272B",
      "border_radius": "12px",
      "align": "center",
      "gap": "12px",
      "highlight_style": {
        "border": "1px solid rgba(74,222,128,0.3)",
        "background": "rgba(74,222,128,0.1)"
      }
    }
  },
  "actions": {
    "padding": "24px",
    "items": [
      {
        "label": "Got it",
        "style": "primary",
        "height": "48px",
        "background": "#B87333",
        "text_color": "rgba(255,255,255,0.92)",
        "border_radius": "20px",
        "font": "16px 600",
        "full_width": true
      }
    ]
  },
  "states": {
    "fahrenheit": "Showing °F ranges",
    "celsius": "Showing °C ranges"
  }
}
