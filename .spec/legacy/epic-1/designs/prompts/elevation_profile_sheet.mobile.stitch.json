{
  "design_key": "elevation_profile_sheet",
  "device": "mobile",
  "screen": "Elevation Profile Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Phase 2: View elevation chart for a route",
  "phase": 2,
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "bottom_partial",
    "height": "40vh",
    "background": "#1A1C1F",
    "border_radius_top": "32px",
    "shadow": "0 -8px 30px rgba(0,0,0,0.5)"
  },
  "header": {
    "drag_handle": {
      "width": "36px",
      "height": "4px",
      "background": "rgba(255,255,255,0.2)",
      "border_radius": "2px",
      "margin_top": "8px"
    },
    "title": {
      "text": "Elevation Profile",
      "style": "20px 600 rgba(255,255,255,0.92)"
    }
  },
  "layout": {
    "type": "vertical",
    "padding": "24px",
    "sections": [
      {
        "id": "stats_summary",
        "type": "stats_row",
        "gap": "24px",
        "margin_bottom": "20px",
        "items": [
          {
            "icon": "trending_up",
            "label": "Total Ascent",
            "value": "2,450 ft",
            "color": "#4ade80"
          },
          {
            "icon": "trending_down",
            "label": "Total Descent",
            "value": "2,120 ft",
            "color": "#f87171"
          },
          {
            "icon": "show_chart",
            "label": "Max Grade",
            "value": "8.2%",
            "color": "#fbbf24"
          }
        ]
      },
      {
        "id": "elevation_chart",
        "type": "chart",
        "chart_type": "area",
        "height": "120px",
        "background": "#24272B",
        "border_radius": "12px",
        "padding": "16px",
        "config": {
          "fill_color": "rgba(184,115,51,0.2)",
          "line_color": "#B87333",
          "line_width": 2,
          "grid_color": "rgba(255,255,255,0.08)",
          "x_axis": {
            "label": "Distance",
            "format": "mi"
          },
          "y_axis": {
            "label": "Elevation",
            "format": "ft"
          }
        }
      },
      {
        "id": "legend_row",
        "type": "row",
        "margin_top": "12px",
        "justify": "center",
        "gap": "16px",
        "items": [
          {
            "type": "legend_item",
            "color": "#4ade80",
            "label": "Ascent"
          },
          {
            "type": "legend_item",
            "color": "#f87171",
            "label": "Descent"
          }
        ]
      }
    ]
  },
  "states": {
    "default": "Elevation chart displayed",
    "loading": "Loading elevation data"
  }
}
