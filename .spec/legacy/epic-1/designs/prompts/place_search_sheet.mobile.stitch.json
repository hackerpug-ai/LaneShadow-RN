{
  "design_key": "place_search_sheet",
  "device": "mobile",
  "screen": "Place Search Sheet (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Full-height search sheet with autocomplete results and recent searches",
  "theme": {
    "background": "#1A1C1F",
    "surface": "#24272B",
    "surface_elevated": "#36302b",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "sheet": {
    "type": "full_height",
    "height": "85vh",
    "background": "#1A1C1F",
    "border_radius_top": "32px",
    "shadow": "0 -8px 30px rgba(0,0,0,0.5)"
  },
  "header": {
    "drag_handle": {
      "width": "36px",
      "height": "4px",
      "background": "rgba(255,255,255,0.2)",
      "border_radius": "2px",
      "margin_top": "8px"
    },
    "search_input": {
      "margin": "16px 24px",
      "background": "#36302b",
      "height": "56px",
      "border_radius": "12px",
      "placeholder": "Search places...",
      "leading_icon": "search",
      "trailing_icon": "close",
      "autofocus": true
    }
  },
  "layout": {
    "type": "scrollable",
    "padding": "0 24px",
    "sections": [
      {
        "id": "recent_searches",
        "type": "chip_row",
        "label": "Recent",
        "label_style": "12px 600 rgba(255,255,255,0.55) uppercase",
        "margin_bottom": "20px",
        "scroll_horizontal": true,
        "gap": "8px",
        "chips": [
          { "label": "San Francisco", "icon": "history" },
          { "label": "Big Sur", "icon": "history" },
          { "label": "Monterey", "icon": "history" }
        ],
        "chip_style": {
          "background": "#24272B",
          "border_radius": "20px",
          "padding": "8px 16px",
          "text_style": "14px 400 text_secondary"
        }
      },
      {
        "id": "search_results",
        "type": "list",
        "gap": "0",
        "divider": {
          "color": "rgba(255,255,255,0.08)",
          "margin_left": "56px"
        },
        "items": "Dynamic search results"
      }
    ]
  },
  "components": {
    "search_result_item": {
      "height": "64px",
      "padding": "12px 0",
      "layout": "horizontal",
      "align": "center",
      "gap": "16px",
      "children": [
        {
          "type": "icon_container",
          "size": "40px",
          "background": "#24272B",
          "border_radius": "12px",
          "icon": "location_on",
          "icon_color": "rgba(255,255,255,0.55)"
        },
        {
          "type": "column",
          "flex": 1,
          "children": [
            { "type": "text", "style": "16px 400 text_primary", "content": "Place Name" },
            { "type": "text", "style": "14px 400 text_muted", "content": "City, State" }
          ]
        }
      ],
      "on_press": "Select and return to PlanRideSheet"
    },
    "current_location_item": {
      "height": "64px",
      "padding": "12px 0",
      "layout": "horizontal",
      "align": "center",
      "gap": "16px",
      "children": [
        {
          "type": "icon_container",
          "size": "40px",
          "background": "rgba(184,115,51,0.2)",
          "border_radius": "12px",
          "icon": "my_location",
          "icon_color": "#B87333"
        },
        {
          "type": "text",
          "style": "16px 500 #B87333",
          "content": "Current Location"
        }
      ]
    }
  },
  "empty_state": {
    "condition": "no_results",
    "content": {
      "icon": "search_off",
      "headline": "No results found",
      "body": "Try a different search term",
      "icon_size": "48px",
      "icon_color": "rgba(255,255,255,0.3)"
    }
  },
  "states": {
    "empty": "Initial state with recent searches",
    "typing": "User entering query, loading indicator",
    "results": "Showing autocomplete results",
    "no_results": "No matches found",
    "loading": "Fetching results spinner"
  }
}
