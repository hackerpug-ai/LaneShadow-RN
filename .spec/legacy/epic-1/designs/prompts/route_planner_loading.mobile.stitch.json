{
  "design_key": "route_planner_loading",
  "device": "mobile",
  "screen": "Route Planner Loading (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Full-screen progress overlay during route planning with status updates",
  "theme": {
    "background": "rgba(14,15,17,0.95)",
    "surface": "#1A1C1F",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "overlay": {
    "type": "full_screen",
    "background": "rgba(14,15,17,0.95)",
    "backdrop_blur": "20px",
    "z_index": 100
  },
  "layout": {
    "type": "centered",
    "padding": "24px",
    "sections": [
      {
        "id": "loading_indicator",
        "type": "spinner",
        "size": "64px",
        "color": "#B87333",
        "animation": "spin",
        "margin_bottom": "32px"
      },
      {
        "id": "status_text",
        "type": "animated_text",
        "style": "18px 500 rgba(255,255,255,0.92)",
        "align": "center",
        "margin_bottom": "8px",
        "states": [
          "Planning your route...",
          "Finding scenic roads...",
          "Checking weather conditions...",
          "Almost there..."
        ]
      },
      {
        "id": "substatus",
        "type": "text",
        "style": "14px 400 rgba(255,255,255,0.55)",
        "align": "center",
        "text": "This usually takes 10-15 seconds"
      },
      {
        "id": "progress_bar",
        "type": "progress",
        "margin_top": "32px",
        "width": "200px",
        "height": "4px",
        "background": "rgba(255,255,255,0.1)",
        "fill_color": "#B87333",
        "border_radius": "2px",
        "animated": true
      }
    ]
  },
  "actions": {
    "position": "absolute",
    "bottom": "100px",
    "width": "100%",
    "padding": "0 24px",
    "items": [
      {
        "label": "Cancel",
        "style": "text",
        "height": "48px",
        "text_color": "rgba(255,255,255,0.55)",
        "font": "16px 400"
      }
    ]
  },
  "states": {
    "planning": {
      "status": "Planning your route...",
      "progress": 25
    },
    "sketching": {
      "status": "Finding scenic roads...",
      "progress": 50
    },
    "compiling": {
      "status": "Compiling route...",
      "progress": 70
    },
    "fetching_conditions": {
      "status": "Checking weather conditions...",
      "progress": 90
    },
    "error": {
      "status": "Something went wrong",
      "progress": 0,
      "transition_to": "planning_error_sheet"
    }
  }
}
