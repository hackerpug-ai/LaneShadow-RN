{
  "design_key": "session_restoring",
  "device": "mobile",
  "screen": "Session Restoring (mobile view)",
  "platform": "mobile-app",
  "ui_library": "react-native-expo",
  "component_style_match": true,
  "dimensions": "390x844",
  "viewport": "mobile",
  "description": "Startup splash screen with session restoration loading",
  "theme": {
    "background": "#1f1913",
    "surface": "#25211e",
    "primary": "#B87333",
    "text_primary": "rgba(255,255,255,0.92)",
    "text_secondary": "rgba(255,255,255,0.72)",
    "text_muted": "rgba(255,255,255,0.55)"
  },
  "layout": {
    "type": "centered",
    "background": "#1f1913",
    "padding": "24px",
    "sections": [
      {
        "id": "logo",
        "type": "app_logo",
        "size": "96px",
        "margin_bottom": "24px",
        "content": "LaneShadow app icon/logo"
      },
      {
        "id": "app_name",
        "type": "text",
        "text": "LaneShadow",
        "style": "32px 600 rgba(255,255,255,0.92)",
        "font_family": "Space Grotesk",
        "margin_bottom": "8px"
      },
      {
        "id": "tagline",
        "type": "text",
        "text": "Plan scenic rides with confidence",
        "style": "14px 400 rgba(255,255,255,0.55)",
        "margin_bottom": "48px"
      },
      {
        "id": "loading_indicator",
        "type": "spinner",
        "size": "32px",
        "color": "#B87333",
        "margin_bottom": "16px"
      },
      {
        "id": "status_text",
        "type": "text",
        "style": "14px 400 rgba(255,255,255,0.55)",
        "text": "Restoring session..."
      }
    ]
  },
  "states": {
    "checking": {
      "status_text": "Checking authentication...",
      "next": "authenticated OR not_authenticated"
    },
    "restoring": {
      "status_text": "Restoring session...",
      "next": "home_map"
    },
    "error": {
      "status_text": "Session expired",
      "next": "auth_sign_in"
    }
  }
}
