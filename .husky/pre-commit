#!/usr/bin/env sh

# Pre-commit checks: all must pass before a commit is accepted

# 1. TypeScript type checking
echo "Running TypeScript type check..."
npm run type-check || exit 1

# 2. ESLint (fail only on errors, warnings allowed)
echo "Running ESLint..."
npx eslint . --max-warnings=-1 || exit 1

# 3. Convex build (push to dev deployment, typecheck, codegen — one-shot)
echo "Running Convex dev --once..."
CONVEX_DEPLOYMENT=dev:quirky-panther-164 npx convex dev --once || exit 1

echo "All pre-commit checks passed."
