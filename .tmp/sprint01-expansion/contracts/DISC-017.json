{
  "fixtures": {
    "live_catalog_located": {
      "description": "plan view against live Convex, signed-in, no active route, useCurrentLocation at Asheville \u2192 useCuratedDiscovery returns >=1 route with name + distanceMi",
      "seed_method": "migration_fixture",
      "records": [
        "seeded catalog",
        "current location {lat:35.5951,lng:-82.5515}"
      ]
    },
    "live_catalog_loading": {
      "description": "plan view rendered at the instant the curated query is still pending (routes undefined)",
      "seed_method": "migration_fixture",
      "records": [
        "query in-flight; isLoading true"
      ]
    },
    "live_catalog_empty": {
      "description": "plan view with a location/bbox yielding zero curated matches",
      "seed_method": "migration_fixture",
      "records": [
        "isEmpty true; routes === []"
      ]
    }
  },
  "requirements": [
    {
      "id": "AC-1",
      "scenario": {
        "start_ref": "live_catalog_located",
        "tier": "visible",
        "negative_control": {
          "would_fail_if": [
            "IDLE_SUGGESTIONS fallback retained",
            "hook disconnected \u2192 prompts shown",
            "cards show generic prompt text"
          ]
        },
        "evidence": {
          "artifact_type": "screenshot",
          "required_capture": true
        },
        "cases": [
          {
            "action": {
              "actor": "user",
              "steps": [
                "render the plan view against live Convex with no active route and a real location",
                "await curated routes to resolve",
                "read the discovery-suggestion-pill rows"
              ]
            },
            "end_state": {
              "must_observe": [
                "at least one pill label contains a real road name and a 'mi' mileage suffix (e.g. a catalog name followed by ' \u00b7 12mi')",
                "each curated pill has testID discovery-suggestion-pill-{routeId}"
              ],
              "must_not_observe": [
                "'Plan a scenic ride'",
                "'Ride to the coast'",
                "'Find coffee nearby'",
                "'Avoid highways'"
              ]
            }
          }
        ],
        "test_tier": "integration",
        "verification_service": "live Convex dev (api.curatedRoutes.listCuratedRoutes) via @testing-library/react-native"
      }
    },
    {
      "id": "AC-2",
      "scenario": {
        "start_ref": "live_catalog_loading",
        "tier": "visible",
        "negative_control": {
          "would_fail_if": [
            "loading state renders IDLE_SUGGESTIONS",
            "loading renders the empty 'no nearby routes' copy prematurely"
          ]
        },
        "evidence": {
          "artifact_type": "stdout",
          "required_capture": true
        },
        "cases": [
          {
            "action": {
              "actor": "user",
              "steps": [
                "render the plan view before the curated query resolves (isLoading true)",
                "query the slot for any suggestion pill or prompt text"
              ]
            },
            "end_state": {
              "must_observe": [
                "zero discovery-suggestion-pill rows present",
                "no 'no nearby routes' copy yet"
              ],
              "must_not_observe": [
                "any IDLE_SUGGESTIONS string",
                "any curated card while loading"
              ]
            }
          }
        ],
        "test_tier": "integration",
        "verification_service": "live Convex dev via @testing-library/react-native"
      }
    },
    {
      "id": "AC-3",
      "scenario": {
        "start_ref": "live_catalog_empty",
        "tier": "visible",
        "negative_control": {
          "would_fail_if": [
            "empty falls back to IDLE_SUGGESTIONS",
            "empty renders nothing (rider sees no feedback)"
          ]
        },
        "evidence": {
          "artifact_type": "screenshot",
          "required_capture": true
        },
        "cases": [
          {
            "action": {
              "actor": "user",
              "steps": [
                "render the plan view with a bbox/location that yields zero curated matches against live Convex",
                "read the slot"
              ]
            },
            "end_state": {
              "must_observe": [
                "a legible empty message containing 'no nearby routes' (or the ratified DESIGN-S01-003 empty copy)"
              ],
              "must_not_observe": [
                "'Plan a scenic ride'",
                "'Find coffee nearby'",
                "'Ride to the coast'",
                "'Avoid highways'",
                "any tappable curated pill"
              ]
            }
          }
        ],
        "test_tier": "integration",
        "verification_service": "live Convex dev via @testing-library/react-native"
      }
    }
  ]
}