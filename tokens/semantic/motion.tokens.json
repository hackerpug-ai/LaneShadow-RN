{
  "motion": {
    "duration": {
      "instant": {
        "$type": "duration",
        "$value": 0
      },
      "fast": {
        "$type": "duration",
        "$value": 120
      },
      "standard": {
        "$type": "duration",
        "$value": 240
      },
      "slow": {
        "$type": "duration",
        "$value": 400
      },
      "deliberate": {
        "$type": "duration",
        "$value": 600
      },
      "verySlow": {
        "$type": "duration",
        "$value": 1400
      }
    },
    "easing": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [0.4, 0.0, 0.2, 1.0]
      },
      "emphasized": {
        "$type": "cubicBezier",
        "$value": [0.2, 0.0, 0.0, 1.0]
      },
      "decelerated": {
        "$type": "cubicBezier",
        "$value": [0.0, 0.0, 0.2, 1.0]
      },
      "accelerated": {
        "$type": "cubicBezier",
        "$value": [0.4, 0.0, 1.0, 1.0]
      },
      "linear": {
        "$type": "cubicBezier",
        "$value": [0.0, 0.0, 1.0, 1.0]
      },
      "easeInOut": {
        "$type": "cubicBezier",
        "$value": [0.4, 0.0, 0.6, 1.0]
      },
      "easeOut": {
        "$type": "cubicBezier",
        "$value": [0.0, 0.0, 0.2, 1.0]
      }
    },
    "chatOverlayEnter": {
      "duration": "{motion.duration.standard}",
      "easing": "{motion.easing.easeOut}",
      "iteration": "once"
    },
    "chatOverlayDismiss": {
      "duration": "{motion.duration.fast}",
      "easing": "{motion.easing.linear}",
      "iteration": "once"
    },
    "sidebarSlideIn": {
      "duration": "{motion.duration.standard}",
      "easing": "{motion.easing.decelerated}",
      "iteration": "once"
    },
    "sketchPolylineLoop": {
      "duration": 1400,
      "easing": "{motion.easing.linear}",
      "iteration": "restart"
    },
    "breathingHeadDot": {
      "duration": 1400,
      "easing": "{motion.easing.easeInOut}",
      "iteration": "reverse"
    },
    "recordDotPulse": {
      "duration": 1400,
      "easing": "{motion.easing.easeInOut}",
      "iteration": "reverse"
    },
    "routeDrawOn": {
      "duration": "{motion.duration.deliberate}",
      "easing": "{motion.easing.decelerated}",
      "iteration": "once"
    },
    "bestBadgeEnter": {
      "duration": 200,
      "easing": "spring",
      "iteration": "once"
    },
    "phaseDotPulse": {
      "duration": "{motion.duration.slow}",
      "easing": "{motion.easing.standard}",
      "iteration": "loop"
    },
    "mapTapDismiss": {
      "duration": "{motion.duration.fast}",
      "easing": "{motion.easing.linear}",
      "iteration": "once"
    }
  }
}
