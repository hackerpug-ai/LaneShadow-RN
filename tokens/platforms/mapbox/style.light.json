{
  "version": 8,
  "name": "LaneShadow Copper Day",
  "metadata": {
    "laneshadow:authority": ".spec/design/system/tokens/theme.light.json",
    "laneshadow:description": "Warm-paper topographic map aligned with LaneShadow light theme (copper accent).",
    "mapbox:type": "default",
    "mapbox:origin": "monochrome-v1"
  },
  "sprite": "mapbox://sprites/mapbox/streets-v12",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sources": {
    "composite": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8,mapbox.mapbox-terrain-v2"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#FDFBF8"
      }
    },
    {
      "id": "national-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse_overlay",
      "filter": ["==", ["get", "class"], "national_park"],
      "paint": {
        "fill-color": "#E8E2D7",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 6, 0.55]
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["in", ["get", "class"], ["literal", ["park", "pitch", "grass", "cemetery"]]],
      "paint": {
        "fill-color": "#E4E2D2",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 11, 0.4, 13, 0.7]
      }
    },
    {
      "id": "landuse-hospital",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "hospital"],
      "paint": {
        "fill-color": "#F4E5DC",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-school",
      "type": "fill",
      "source": "composite",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "school"],
      "paint": {
        "fill-color": "#F2EADB",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "hillshade-faint",
      "type": "fill",
      "source": "composite",
      "source-layer": "hillshade",
      "filter": ["==", ["get", "class"], "shadow"],
      "paint": {
        "fill-color": "#49454F",
        "fill-opacity": 0.06
      }
    },
    {
      "id": "contour",
      "type": "line",
      "source": "composite",
      "source-layer": "contour",
      "minzoom": 11,
      "paint": {
        "line-color": "#49454F",
        "line-opacity": ["case", ["==", ["%", ["get", "ele"], 100], 0], 0.22, 0.10],
        "line-width": ["case", ["==", ["%", ["get", "ele"], 100], 0], 0.7, 0.4]
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "composite",
      "source-layer": "water",
      "paint": {
        "fill-color": "#D9E4EC"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "composite",
      "source-layer": "waterway",
      "minzoom": 8,
      "paint": {
        "line-color": "#C6D3DE",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 16, 2]
      }
    },
    {
      "id": "aeroway-runway",
      "type": "fill",
      "source": "composite",
      "source-layer": "aeroway",
      "filter": ["==", ["geometry-type"], "Polygon"],
      "paint": { "fill-color": "#EDE7E1" }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "composite",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#F2EFED",
        "fill-outline-color": "#E5DED9",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 14, 0, 15, 1]
      }
    },
    {
      "id": "tunnel-street-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["all",
        ["==", ["get", "structure"], "tunnel"],
        ["in", ["get", "class"], ["literal", ["street", "street_limited"]]]
      ],
      "paint": {
        "line-color": "#C9BDB3",
        "line-dasharray": [1, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.5, 18, 10]
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["path", "pedestrian", "track"]]],
      "minzoom": 14,
      "paint": {
        "line-color": "#C9BDB3",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 14, 0.5, 18, 2]
      }
    },
    {
      "id": "road-street",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["street", "street_limited", "service"]]],
      "minzoom": 12,
      "paint": {
        "line-color": "#F2EFED",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.5, 18, 14]
      }
    },
    {
      "id": "road-street-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["street", "street_limited"]]],
      "minzoom": 13,
      "paint": {
        "line-color": "#E5DED9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 13, 0.5, 18, 16],
        "line-gap-width": 0
      },
      "layout": {}
    },
    {
      "id": "road-secondary-tertiary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["secondary", "tertiary"]]],
      "paint": {
        "line-color": "#EDE7E1",
        "line-width": ["interpolate", ["linear"], ["zoom"], 9, 0.3, 18, 10]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "primary"],
      "paint": {
        "line-color": "#E5DED9",
        "line-width": ["interpolate", ["linear"], ["zoom"], 7, 0.3, 18, 13]
      }
    },
    {
      "id": "road-trunk-casing",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk"]]],
      "paint": {
        "line-color": "#9E4A22",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.3, 18, 15]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk"]]],
      "paint": {
        "line-color": "#EE7C2B",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.2, 18, 12]
      }
    },
    {
      "id": "bridge-trunk",
      "type": "line",
      "source": "composite",
      "source-layer": "road",
      "filter": ["all",
        ["==", ["get", "structure"], "bridge"],
        ["in", ["get", "class"], ["literal", ["motorway", "trunk"]]]
      ],
      "paint": {
        "line-color": "#EE7C2B",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.3, 18, 12]
      }
    },
    {
      "id": "admin-state-province",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["all", ["==", ["get", "admin_level"], 1], ["!=", ["get", "disputed"], "true"]],
      "paint": {
        "line-color": "#C9BDB3",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.3, 12, 1.5]
      }
    },
    {
      "id": "admin-country",
      "type": "line",
      "source": "composite",
      "source-layer": "admin",
      "filter": ["all", ["==", ["get", "admin_level"], 0], ["!=", ["get", "disputed"], "true"]],
      "paint": {
        "line-color": "#6B6460",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.5, 10, 2]
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary", "street"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "symbol-placement": "line",
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 18, 13],
        "text-letter-spacing": 0.02
      },
      "paint": {
        "text-color": "#6B6460",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 1.25
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "composite",
      "source-layer": "poi_label",
      "minzoom": 14,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 14, 10, 18, 12],
        "text-max-width": 8,
        "text-anchor": "top",
        "text-offset": [0, 0.6]
      },
      "paint": {
        "text-color": "#49454F",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 1.25
      }
    },
    {
      "id": "place-neighborhood",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "neighbourhood"],
      "minzoom": 12,
      "layout": {
        "text-field": ["upcase", ["coalesce", ["get", "name_en"], ["get", "name"]]],
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 10, 16, 13],
        "text-letter-spacing": 0.15
      },
      "paint": {
        "text-color": "#6B6460",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-locality",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["in", ["get", "type"], ["literal", ["village", "town", "suburb"]]],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 11, 14, 16]
      },
      "paint": {
        "text-color": "#1E1A16",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 1.75
      }
    },
    {
      "id": "place-city",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "city"],
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Offc Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 12, 10, 20]
      },
      "paint": {
        "text-color": "#1E1A16",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-state",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "state"],
      "maxzoom": 7,
      "layout": {
        "text-field": ["upcase", ["coalesce", ["get", "name_en"], ["get", "name"]]],
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 3, 10, 7, 16],
        "text-letter-spacing": 0.2
      },
      "paint": {
        "text-color": "#6B6460",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "place-country",
      "type": "symbol",
      "source": "composite",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "country"],
      "maxzoom": 5,
      "layout": {
        "text-field": ["upcase", ["coalesce", ["get", "name_en"], ["get", "name"]]],
        "text-font": ["DIN Offc Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 1, 11, 5, 20],
        "text-letter-spacing": 0.25
      },
      "paint": {
        "text-color": "#1E1A16",
        "text-halo-color": "#FDFBF8",
        "text-halo-width": 2
      }
    }
  ]
}
