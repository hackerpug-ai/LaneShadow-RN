{
  "motion": {
    "duration": {
      "instant": {
        "$type": "duration",
        "$value": 0
      },
      "fast": {
        "$type": "duration",
        "$value": 120
      },
      "standard": {
        "$type": "duration",
        "$value": 240
      }
    },
    "easing": {
      "standard": {
        "$type": "cubicBezier",
        "$value": [0.4, 0.0, 0.2, 1.0]
      },
      "emphasized": {
        "$type": "cubicBezier",
        "$value": [0.2, 0.0, 0.0, 1.0]
      }
    },
    "recipeWithoutEasing": {
      "duration": "{motion.duration.standard}",
      "iteration": "once"
    }
  }
}
