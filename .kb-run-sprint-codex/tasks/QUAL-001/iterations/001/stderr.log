    _maybe_set(payload, route, "editorial_rank", "editorialRank")
    _maybe_set(payload, route, "source_rank", "sourceRank")
    _maybe_set(payload, route, "source_rank_kind", "sourceRankKind")
    _maybe_set(payload, route, "source_collection", "sourceCollection")
    _maybe_set(payload, route, "source_collection_title", "sourceCollectionTitle")
    _maybe_set(payload, route, "ground_truth_notes", "groundTruthNotes")
    _maybe_set(payload, route, "related_article_url", "relatedArticleUrl")
    _maybe_set(payload, route, "related_article_title", "relatedArticleTitle")
    _maybe_set(payload, route, "state_raw", "stateRaw")
    _maybe_set(payload, route, "states_all", "statesAll")
    _maybe_set(payload, route, "highway_number", "highwayNumber")
    _maybe_set(payload, route, "elevation_gain_m", "elevationGainM")
    _maybe_set(payload, route, "surface", "surface")
    _maybe_set(payload, route, "aadt", "aadt")
    _maybe_set(payload, route, "aadt_median", "aadtMedian")
    _maybe_set(payload, route, "aadt_max", "aadtMax")
    _maybe_set(payload, route, "pavement_iri", "pavementIri")
    _maybe_set(payload, route, "mention_frequency", "mentionFrequency")

    # Add enriched fields if present (EnrichedRoute extends Route)
    if hasattr(route, "composite_score"):
