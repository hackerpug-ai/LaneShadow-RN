        \"status\": \"success\",
        \"value\": {
            \"result\": [
                {
                    \"routeId\": item[\"routeId\"],
                    \"cosineSimilarity\": item[\"cosineSimilarity\"],
                    \"name\": item.get(\"name\", \"Unknown\"),
                    \"state\": item.get(\"state\", \"TN\"),
                    \"candidateIdentifiers\": item.get(\"candidateIdentifiers\", []),
                }
                for item in neighbors
            ],
            \"forRoute\": route_id,
        },
    }


