{
  "name": "@laneshadow/react-native",
  "version": "1.0.0",
  "private": true,
  "description": "LaneShadow React Native / Expo app",
  "main": "./index.js",
  "scripts": {
    "dev": "expo start --ios",
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "type-check": "tsgo --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --clear",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "storybook:generate": "sb-rn-get-stories"
  },
  "dependencies": {
    "expo": "~54.0.31",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
