#!/usr/bin/env bash
# kb-run-sprint-codex-stop
#
# Codex Stop hooks have a stricter stdout contract than other hooks:
# stdout must be empty or valid Stop-hook JSON. Human-readable logs on stdout
# make Codex report "hook returned invalid stop hook JSON".
#
# The global ~/.codex/hooks/kb_run_stop.sh owns normal kb-run enforcement:
# commit accountability, clean worktree checks, state integrity, and runtime
# commands from KB_TYPECHECK_CMD / KB_LINT_CMD / KB_TEST_CMD. This repo-local
# hook is intentionally quiet by default so normal Codex turns do not run a
# heavy validation suite at every assistant stop.

set -u

# Consume the hook JSON payload so callers that pipe stdin never see EPIPE.
cat >/dev/null || true

# Only kb-run child sessions should be governed by this hook.
if [ "${KB_RUN_ACTIVE:-}" != "1" ] && [ -z "${KB_TASK_ID:-}" ]; then
    exit 0
fi

# Project-local gates are opt-in. The global kb-run Stop hook already runs the
# task-specific gates configured by the orchestrator, so duplicate repo checks
# should be enabled only for diagnosis or explicit hardening.
if [ "${KB_PROJECT_STOP_GATES:-0}" != "1" ]; then
    exit 0
fi

PROJECT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
LOG_DIR="${TMPDIR:-/tmp}/laneshadow-codex-hooks"
mkdir -p "$LOG_DIR"
LOG_FILE="$LOG_DIR/kb-run-sprint-codex-stop-${KB_TASK_ID:-unknown}-$$.log"

run_gate() {
    local name="$1"
    local command="$2"

    {
        printf '\n== %s ==\n' "$name"
        printf '$ %s\n' "$command"
    } >>"$LOG_FILE"

    if (cd "$PROJECT_ROOT" && bash -lc "$command") >>"$LOG_FILE" 2>&1; then
        printf '%s\n' "PASS: $name" >>"$LOG_FILE"
        return 0
    fi

    printf '%s\n' "FAIL: $name" >>"$LOG_FILE"
    return 1
}

FAILED=0

if command -v pnpm >/dev/null 2>&1; then
    run_gate "typecheck" "pnpm run --if-present type-check:native" || FAILED=1
    run_gate "lint" "pnpm run --if-present lint" || FAILED=1
    run_gate "tests" "pnpm run --if-present test" || FAILED=1
else
    {
        printf 'pnpm not found; skipping project-local Stop gates.\n'
        printf 'Install pnpm or rely on the global kb-run gate commands.\n'
    } >>"$LOG_FILE"
fi

if [ "$FAILED" -eq 0 ]; then
    exit 0
fi

python3 - "$LOG_FILE" <<'PY'
import json
import pathlib
import sys

log_path = pathlib.Path(sys.argv[1])
log = log_path.read_text(errors="replace")
if len(log) > 4000:
    log = log[-4000:]

reason = (
    "Project-local Stop gates failed. Fix the failures below, then stop again.\n\n"
    f"{log}\n\nFull log: {log_path}"
)
print(json.dumps({"decision": "block", "reason": reason}))
PY
