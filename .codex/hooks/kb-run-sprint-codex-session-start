#!/bin/bash
# kb-run-sprint-codex-session-start — Project-owned session initialization hook
#
# This hook runs when a new codex session starts for a task. It initializes
# the session state and tracks the worktree association.
#
# Orchestrator installs this into target project's .codex/hooks/ during --bootstrap.
#
# This hook is called by the orchestrator with environment variables:
#   - CODEX_SESSION_ID — UUID of the new codex session
#   - CODEX_WORKTREE_PATH — Path to the worktree (if applicable)
#   - CODEX_TASK_ID — Task ID being executed
#   - CODEX_ROLE — Role (implementer or reviewer)

set -euo pipefail

SESSION_ID="${CODEX_SESSION_ID:-}"
WORKTREE_PATH="${CODEX_WORKTREE_PATH:-}"
TASK_ID="${CODEX_TASK_ID:-}"
ROLE="${CODEX_ROLE:-}"

# Create .kb-run-sprint-codex directory structure if it doesn't exist
mkdir -p ".kb-run-sprint-codex/iterations"
mkdir -p ".kb-run-sprint-codex/sessions"

# Initialize state.json if it doesn't exist
if [ ! -f ".kb-run-sprint-codex/state.json" ]; then
    cat > ".kb-run-sprint-codex/state.json" << EOF
{
  "sprint_id": "$(uuidgen 2>/dev/null || echo 'unknown')",
  "started_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "max_iterations": 5,
  "max_kickbacks": 3,
  "tasks": {},
  "active_processes": {},
  "reaped_processes": []
}
EOF
fi

# Log session start
SESSION_LOG=".kb-run-sprint-codex/sessions/${SESSION_ID}.log"
cat > "$SESSION_LOG" << EOF
{
  "session_id": "$SESSION_ID",
  "task_id": "$TASK_ID",
  "role": "$ROLE",
  "worktree_path": "$WORKTREE_PATH",
  "started_at": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "hostname": "$(hostname)",
  "pid": $$,
  "cwd": "$(pwd)"
}
EOF

echo "🚀 Codex session initialized"
echo "   Session ID: $SESSION_ID"
echo "   Task: $TASK_ID"
echo "   Role: $ROLE"
if [ -n "$WORKTREE_PATH" ]; then
    echo "   Worktree: $WORKTREE_PATH"
fi

# Stamp state checksum for Stop hook integrity check
GIT_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
STATE_FILE="$GIT_ROOT/.kb-run-sprint-codex/state.json"
if [ -f "$STATE_FILE" ]; then
    shasum -a 256 "$STATE_FILE" > "$GIT_ROOT/.kb-run-sprint-codex/.state.json.sha256"
fi

exit 0
