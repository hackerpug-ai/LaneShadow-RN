      });
    },
    
    async executeTask(input: AgentInput): Promise<AgentOutput> {
      // Implementation using composed functions
    }
  };
};
```

## Data Validation & Type Safety

### Convex Validator-First Approach (`v` for backend schema/args/returns)
```typescript
import { Infer, v } from 'convex/values'

// ✅ Define field validators (source of truth)
export const PRODUCT_FIELDS = {
  id: v.string(),
  name: v.string(),
} as const

// ✅ Use object validator in schema + server function args/returns
export const productValidator = v.object(PRODUCT_FIELDS)

// ✅ Derive TS type from validator
export type Product = Infer<typeof productValidator>
```

### Error Handling
```typescript
// ✅ Functional error handling
export const createErrorHandlers = () => ({
  handleDatabaseError: (error: any, operation: string): never => {
    throw new DatabaseError(`${operation} failed: ${error.message}`);
  },
  
  handleValidationError: (error: unknown, context: string): never => {
    const message = error instanceof Error ? error.message : String(error)
    throw new ValidationError(`Validation failed in ${context}: ${message}`);
  }
});

// ✅ Use Result types for operations that can fail
export type Result<T, E = Error> = 
  | { success: true; data: T }
  | { success: false; error: E };

export const tryOperation = async <T>(
  operation: () => Promise<T>
): Promise<Result<T>> => {
  try {
    const data = await operation();
    return { success: true, data };
  } catch (error) {
    return { success: false, error: error as Error };
  }
};
```

### Environment Variable Pattern
```typescript
// ✅ Centralized environment variable loading
// src/env.ts
type EnvLoader = {
  (key: string, defaultValue?: string): string;
  (key: string, defaultValue: string): string;
};

const loadEnvVariable: EnvLoader = (key: string, defaultValue?: string): string => {
  const value = process.env[key];
  
  if (value === undefined || value === '') {
    if (defaultValue !== undefined) {
      console.warn(`⚠️  Environment variable ${key} not found, using default: ${defaultValue}`);
      return defaultValue;
    } else {
      console.warn(`⚠️  Environment variable ${key} not found and no default provided`);
      throw new Error(`Missing required environment variable: ${key}`);
    }
  }
  
  return value;
};

export const env = {
  SUPABASE_ID: loadEnvVariable('SUPABASE_ID'),
  SUPABASE_SERVICE_KEY: loadEnvVariable('SUPABASE_SERVICE_KEY'),
  PORT: loadEnvVariable('PORT', '3000'),
  NODE_ENV: loadEnvVariable('NODE_ENV', 'development'),
} as const;

// ✅ Usage in other modules
import { env } from '../../env';

const supabaseUrl = `https://${env.SUPABASE_ID}.supabase.co`;
export const supabase = createClient(supabaseUrl, env.SUPABASE_SERVICE_KEY);
```

## Module Organization

### File Structure
```typescript
// ✅ Organize by feature/component, not by technical layer
src/components/
├── api-gateway/
│   ├── routes/
│   ├── middleware/
│   └── index.ts          // Re-exports public interface
├── database-layer/
│   ├── models/
│   ├── datasources/
│   │   ├── shared/       // Shared utilities
│   │   ├── product.datasource.ts
│   │   └── index.ts      // Re-exports all datasources
│   └── index.ts
```

### Export Patterns
```typescript
// ✅ Clean module exports
// datasources/index.ts
export { productDatasource } from './product.datasource';
export { userDatasource } from './user.datasource';
export { researchDatasource } from './research.datasource';

// ✅ Barrel exports for models
// models/index.ts
export * from './product.models';
export * from './user.models';
export * from './research.models';
```

## Testing Patterns

