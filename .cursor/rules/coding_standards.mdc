      : null;
    
    // Implementation logic
  },
  
  async getResearchStatus(sessionId: string): Promise<ResearchStatus> {
    // Implementation logic
  }
});

export const researchService = createResearchService();
```

### Agent Pattern
```typescript
// ❌ Avoid: Heavy class-based agents
export class MidnightAtlasAgent extends MastraAgent {
  constructor(dependencies...) {
    super(config);
  }
}

