```typescript
// ✅ Test pure functions easily
describe('productDatasource', () => {
  it('should validate product data correctly', () => {
    const mockData = { name: 'Test Product', brand: 'Test Brand' };
    const result = validation.validate(CreateProductSchema, mockData);
    expect(result.name).toBe('Test Product');
  });
});

// ✅ Mock composed dependencies
const mockDatabase = {
  executeQuery: jest.fn()
};

jest.mock('./shared/database', () => ({
  createDatabaseUtils: () => mockDatabase
}));
```

