  // Try to create care log - should fail
  await expect(async () => {
    await t.action(internal.assistant.callTool, {
      threadId,
      tool: 'create_care_log',
      args: { childId: childInButterflyRoom._id },
    })
  }).rejects.toThrow('You do not have access to')
})

// ✅ DO: Test same-classroom success
test('AI can create care log within teacher scope', async () => {
  const { threadId, childInSameClassroom } = await setupSameClassroom(t)
  
  const result = await t.action(internal.assistant.callTool, {
    threadId,
    tool: 'create_care_log',
    args: { childId: childInSameClassroom._id },
  })
  
  expect(result.draftId).toBeDefined()
})
```

### 21. Test Approval Workflow

**Rule:** Test complete flow: draft creation → edit → approve → verify record created.

```typescript
// ✅ DO: Test full approval workflow
test('draft approval workflow', async () => {
  const t = convexTest(schema)
  
  // 1. AI creates draft
  const { draftId } = await t.mutation(api.assistant.proposeAction, { ... })
  
  // 2. Verify draft exists
  const draft = await t.run(ctx => ctx.db.get(draftId))
  expect(draft.status).toBe('draft')
  
  // 3. Edit draft
  await t.mutation(api.assistant.updateDraft, {
    draftId,
    updates: { notes: 'Edited notes' },
  })
  
  // 4. Approve draft
  const { recordId } = await t.mutation(api.assistant.approveDraft, { draftId })
  
  // 5. Verify record created
  const careLog = await t.run(ctx => ctx.db.get(recordId))
  expect(careLog).toBeDefined()
  expect(careLog.notes).toBe('Edited notes')
  
  // 6. Verify draft status updated
  const approvedDraft = await t.run(ctx => ctx.db.get(draftId))
  expect(approvedDraft.status).toBe('approved')
  expect(approvedDraft.createdRecordId).toBe(recordId)
})
```

## Architecture Decisions

### 22. Component vs Library Decision

**Rule:** Do NOT use @convex-dev/agent component. Use Claude Agent SDK as library with your own tables.

**Rationale:**

**Convex Agent Component:**
- ❌ Creates isolated `component.threads` and `component.messages` tables
- ❌ Splits messaging system (AI separate from human chats)
- ❌ No unified inbox
- ❌ Cannot add AI to human group chats later
- ❌ Vendor lock-in on data model
- ✅ Turnkey solution (streaming, RAG, usage tracking built-in)

**Claude Agent SDK (Library):**
- ✅ Integrates with YOUR threads/messages tables
- ✅ Unified messaging (AI + human conversations together)
- ✅ Future-proof for mixed human/AI chats
- ✅ Full data ownership
- ✅ Custom scope enforcement with direct table access
- ❌ Build ~400 lines yourself (placeholder pattern, guards, tools)

**Decision:** Unified messaging is more valuable than turnkey features.

**Trade-off Accepted:**
- Build placeholder pattern (~50 lines)
- Build scope guards (~200 lines)  
- Build custom tools (~150 lines)
- Total: ~400 lines to maintain unified architecture

## Common Patterns

### 23. Agent User Lookup

**Rule:** Query agent users by capabilities, not by hardcoded IDs.

```typescript
// ✅ DO: Query by capabilities
const teachingAssistant = await ctx.db
  .query('agents')
  .filter(q => q.eq(q.field('capabilities'), ['care_logs', 'posts', 'scheduling']))
  .first()

const agentUser = await ctx.db
  .query('users')
  .withIndex('by_agent_id', q => q.eq('agentId', teachingAssistant._id))
  .first()

// ❌ DON'T: Hardcode agent IDs
const agentUser = await ctx.db.get('hardcoded_id_123')
```

### 24. Thread Participant Detection

**Rule:** Detect AI threads by checking if any participant has `userType='agent'`.

```typescript
// ✅ DO: Check participant types
const participants = await ctx.db.query('threadParticipants')
  .withIndex('by_thread_id', q => q.eq('threadId', threadId))
  .collect()

let hasAgentParticipant = false
for (const p of participants) {
  if (p.userId) {
    const user = await ctx.db.get(p.userId)
    if (user?.userType === 'agent') {
      hasAgentParticipant = true
      break
    }
  }
}

// ❌ DON'T: Add special thread.kind='assistant' field
threads: defineTable({
  kind: v.union(v.literal('direct'), v.literal('group'), v.literal('assistant')),
  // Adds complexity - participant check is sufficient
})
```

**Why:** Thread structure is universal, participant types determine presentation (UX decision, not data model).

### 25. DRY: Reuse Validators

**Rule:** Never duplicate enum validators. Import shared validators from `validators.ts`.

```typescript
// ✅ DO: Reuse shared validators
import { CareLogTypeSchema, AgentDraftKindSchema, MessageStatusSchema } from './validators'

agentDrafts: defineTable({
  kind: AgentDraftKindSchema, // Reuse validator
  careLogData: v.optional(v.object({
    type: CareLogTypeSchema, // Reuse validator
  })),
  status: AgentDraftStatusSchema, // Reuse validator
})

messages: defineTable({
  status: v.optional(MessageStatusSchema), // Reuse validator
})

// ❌ DON'T: Duplicate enum literals
agentDrafts: defineTable({
  kind: v.union(
    v.literal('announcement'),
    v.literal('message'),
    v.literal('care_log'), // Duplicates validator
  ),
})
```

**Why:**
- Single source of truth
- Change enum once, updates everywhere
- Type safety across schema and functions
- Easier refactoring

**Common Shared Validators:**
- `ScopeSchema` - 'school' | 'campus' | 'classroom' | 'child'
- `RoleSchema` - All user roles
- `CareLogTypeSchema` - 'diaper' | 'feeding' | 'nap' | 'mood'
- `AgentDraftKindSchema` - Draft types
- `AgentDraftStatusSchema` - Draft lifecycle
- `MessageStatusSchema` - Message async states

## Summary

**Key Rules:**
1. ✅ Agents as users (reference agents table)
2. ✅ Unified messaging (no components)
3. ✅ Human-in-the-loop approval (drafts pattern)
4. ✅ Scope enforcement (every tool)
5. ✅ Organized structure (convex/agents/ for agent configs, convex/actions/ai/ for AI constants)
6. ✅ AI constants centralized (convex/actions/ai/constants.ts and prompts.ts)
7. ✅ Placeholder messages (no streaming in MVP)
8. ✅ Explicit types (tool handlers)
9. ✅ Error handling (catch and return to AI)
10. ✅ Rate limiting (50 messages/hour)
11. ✅ Test scope violations
12. ✅ DRY validators (reuse from validators.ts)

**Anti-Patterns:**
- ❌ Don't use Convex Agent Component (splits messaging)
- ❌ Don't skip scope validation (security risk)
- ❌ Don't create records directly (need approval)
- ❌ Don't add streaming deltas in MVP (complexity)
- ❌ Don't embed agent config in users table (use agents table)
- ❌ Don't place AI constants in validators.ts or root convex/ (use convex/actions/ai/)

