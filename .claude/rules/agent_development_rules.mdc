**File Structure:**

```typescript
// config.ts - Agent configuration
export const MY_AGENT_CONFIG = {
  agentId: 'my-agent',
  displayName: 'My Agent Name',
  model: 'claude-sonnet-4-20250514',
  systemPrompt: `You are a helpful assistant for...`,
} as const

// tools.ts - Custom tools
export const myTool = (ctx: ActionCtx, threadId: Id<'threads'>) =>
  tool('my_tool', 'Description', schema, async (args) => {
    await requireAIScopeAction(ctx, threadId, { ... })
    await ctx.runMutation(internal.db.agentDrafts.createMyDraft, { ... })
  })

// index.ts - MCP server setup
export const createMyAgentTools = (ctx: ActionCtx, threadId: Id<'threads'>) => {
  return createSdkMcpServer({
    name: 'my-agent',
    version: '1.0.0',
    tools: [myTool(ctx, threadId)],
  })
}
```

**Why:** Clear separation of concerns, easy to add new agents, maintainable structure.

## Loading State Pattern

### 6. Placeholder Messages (No Streaming in MVP)

**Rule:** Use placeholder messages with `status='generating'` for loading state. Defer streaming deltas to later sprints.

```typescript
// ✅ DO: Create placeholder, update when complete
export const sendMessage = mutation({
  handler: async (ctx, args) => {
    // Create user message
    const userMessageId = await ctx.db.insert('messages', {
      body: args.content,
      status: 'sent',
    })
    
    // Create placeholder (empty, generating)
    const placeholderMessageId = await ctx.db.insert('messages', {
      authorId: agentUser._id,
      body: '',
      status: 'generating', // UI shows loading spinner
    })
    
    // Schedule AI to update placeholder
    await ctx.scheduler.runAfter(0, internal.assistant.generateResponse, {
      threadId,
      placeholderMessageId,
    })
  }
})

// Action updates placeholder when done
export const generateResponse = internalAction({
  handler: async (ctx, args) => {
    const response = await callClaude(...)
    
    // Update placeholder with final content
    await ctx.runMutation(internal.assistant.updatePlaceholderMessage, {
      placeholderMessageId: args.placeholderMessageId,
      finalContent: response,
      status: 'completed',
    })
  }
})

// ❌ DON'T: Use streaming deltas in MVP (defer to later sprint)
messageDeltas: defineTable({
  tempMessageId: v.string(),
  deltaIndex: v.number(),
  deltaContent: v.string(),
})
// Adds complexity for minimal UX gain in MVP
```

**Why:**
- Simpler implementation for MVP
- Good enough UX with loading spinner
- Defer streaming to Sprint 06+ if needed
- Reduces scope and implementation time

## Tool Development Best Practices

### 7. Tool Naming and Descriptions

**Rule:** Tool names should be action-oriented, descriptions should include approval context.

```typescript
// ✅ DO: Clear naming with approval context
tool(
  'create_care_log',
  'Create a DRAFT care log for teacher approval (nap, feeding, diaper, mood). Teacher must approve before it is published.',
  schema,
  handler
)

// ❌ DON'T: Vague or misleading descriptions
tool(
  'care_log',
  'Care log',
  schema,
  handler
)
// Unclear what it does, doesn't mention draft/approval
```

### 8. Error Handling in Tools

**Rule:** Tools must catch scope validation errors and return user-friendly messages to AI.

```typescript
// ✅ DO: Catch errors and return to AI
async (args) => {
  try {
    await requireAIScopeAction(ctx, threadId, { ... })
    const draftId = await ctx.runMutation(...)
    
    return {
      content: [{ type: 'text', text: "Draft created for review." }],
      metadata: { draftId },
    }
  } catch (error: any) {
    // Catch and return to AI with clear message
    return {
      content: [{
        type: 'text',
        text: `I cannot create that care log: ${error.message}`,
      }],
      isError: true,
    }
  }
}

// ❌ DON'T: Let errors bubble up
async (args) => {
  await requireAIScopeAction(ctx, threadId, { ... }) // Throws, breaks AI flow
  const draftId = await ctx.runMutation(...)
}
```

**Why:** AI can gracefully explain limitations to user rather than showing error stack traces.

### 9. Type Annotations for Tool Handlers

**Rule:** Always provide explicit type annotations for tool handler arguments to avoid TypeScript 'any' errors.

```typescript
// ✅ DO: Explicit type annotation
tool(
  'create_care_log',
  description,
  {
    childId: z.string(),
    type: z.enum(['diaper', 'feeding', 'nap', 'mood']),
    notes: z.string(),
  },
  async (args: { childId: string; type: 'diaper' | 'feeding' | 'nap' | 'mood'; notes: string }) => {
    // TypeScript knows arg types
  }
)

// ❌ DON'T: Implicit types
async (args) => {
  // Error: Parameter 'args' implicitly has an 'any' type
}
```

## Agent Configuration

### 10. System Prompts

**Rule:** System prompts must define role, constraints, available actions, and best practices.

```typescript
// ✅ DO: Comprehensive system prompt
export const TEACHING_ASSISTANT_CONFIG = {
  systemPrompt: `You are a helpful teaching assistant for Montessori schools.

Your role:
- Help teachers create care logs for children
- Draft posts and announcements for parents
- Provide guidance on Montessori practices

Important constraints:
- You can ONLY create care logs for classrooms the teacher has access to
- Always confirm child names and details before creating records
- All actions create DRAFTS that require teacher approval

Available actions:
- create_care_log: Create draft care log (nap, feeding, diaper, mood)
- create_post: Draft post/announcement for parents

Best practices:
- Confirm details: "Just to confirm, you want to create a nap log for Lily?"
- Provide context: "I'll draft this for Sunflower Room since that's where Lily is enrolled."
- Respect boundaries: "I can only create care logs for children in classrooms you teach."`,
}

// ❌ DON'T: Vague or minimal prompt
export const BAD_CONFIG = {
  systemPrompt: "You are a teaching assistant. Help teachers.",
}
```

### 11. Agent Capabilities

**Rule:** Define capabilities array that matches available tools.

```typescript
// ✅ DO: Capabilities match available tools
agents: defineTable({
  capabilities: v.array(v.string()), // ['care_logs', 'posts', 'scheduling']
})

// Tools check capabilities
const teachingAssistant = await ctx.db
  .query('agents')
  .filter(q => q.eq(q.field('capabilities'), ['care_logs', 'posts', 'scheduling']))
  .first()

// ❌ DON'T: Capabilities don't match tools
capabilities: ['care_logs'] // But provides create_post tool (mismatch)
```

## Rate Limiting

### 12. Per-User Rate Limits

**Rule:** Enforce rate limits to prevent abuse (50 messages/hour per user).

```typescript
// ✅ DO: Check rate limit before processing
export const sendMessage = mutation({
  handler: async (ctx, args) => {
    const { thread, userId } = await requireThreadAccess(ctx, args.threadId)
    
    // Check rate limit
    await requireAIRateLimit(ctx, userId, thread.organizationId)
    
    // Proceed with message
  }
})

// ❌ DON'T: Skip rate limiting
export const sendMessage = mutation({
  handler: async (ctx, args) => {
    // No rate check - allows unlimited messages
  }
})
```

**Configuration:**
- 50 messages/hour per user (prevents token cost abuse)
- Count user messages only (not AI responses)
- Return clear error: "Rate limit exceeded (50/hour)"

## Draft Management

### 13. Draft Data Structure

**Rule:** Store structured data in `careLogData` or similar fields, not just text in `inputText`.

```typescript
// ✅ DO: Structured data for programmatic approval
agentDrafts: defineTable({
  kind: v.literal('care_log'),
  careLogData: v.object({
    childId: v.id('children'),
    classroomId: v.id('classrooms'),
    type: v.union(v.literal('diaper'), v.literal('feeding'), ...),
    occurredAt: v.number(),
    notes: v.string(),
  }),
  inputText: v.string(), // For display only
})

// Approval creates record from structured data
const careLogId = await ctx.db.insert('careLogs', draft.careLogData)

// ❌ DON'T: Only store text
agentDrafts: defineTable({
  inputText: v.string(), // "nap - Lily - 1.5 hours"
  // No structured data - have to parse text on approval
})
```

**Why:** Programmatic approval, no parsing required, type-safe, editable fields.

### 14. Draft Lifecycle

**Rule:** Draft status must follow: draft → approved/discarded → (if approved) creates record.

```typescript
// ✅ DO: Proper status transitions
status: v.union(
  v.literal('draft'),      // AI created, awaiting approval
  v.literal('approved'),    // User approved, record created
  v.literal('submitted'),   // Alternative: actually published
  v.literal('discarded')    // User rejected
)

// Approval flow
if (draft.status !== 'draft') {
  throw new Error('Draft already processed')
}

await ctx.db.patch(draftId, { status: 'approved', createdRecordId })

// ❌ DON'T: Skip status checks
await ctx.db.patch(draftId, { status: 'approved' })
// No validation - can approve already-approved drafts
```

### 15. Draft Editing

**Rule:** Allow users to edit drafts before approval. Validate only drafts (status='draft') can be edited.

```typescript
// ✅ DO: Check status before edit
export const updateDraft = mutation({
  handler: async (ctx, args) => {
    const draft = await ctx.db.get(args.draftId)
    
    if (draft.status !== 'draft') {
      throw new Error('Can only edit drafts with status=draft')
    }
    
    await ctx.db.patch(args.draftId, {
      careLogData: {
        ...draft.careLogData,
        notes: args.updates.notes ?? draft.careLogData.notes,
      },
    })
  }
})

// ❌ DON'T: Allow editing approved/discarded drafts
export const updateDraft = mutation({
  handler: async (ctx, args) => {
    // No status check - can edit approved drafts (breaks audit trail)
    await ctx.db.patch(args.draftId, { ... })
  }
})
```

## Security

### 16. Validate Human User Scope (Not Agent Scope)

**Rule:** Scope validation checks the HUMAN user's permissions, not the agent user's.

```typescript
// ✅ DO: Validate thread creator (human) scope
export const requireAIScopeAction = async (ctx, threadId, action) => {
  const thread = await ctx.runQuery(api.db.session.getThreadById, { threadId })
  
  // Get HUMAN user (thread creator)
  const userId = thread.createdBy // Human, not agent
  
  // Check HUMAN user's assignments
  const assignments = await ctx.runQuery(api.db.assignments.getUserAssignmentsInternal, {
    userId, // Human user ID
    organizationId: thread.organizationId,
  })
  
  // Validate human has access
  const match = assignments.find(a => a.scopeType === targetScope.type && ...)
}

// ❌ DON'T: Check agent user's permissions
export const requireAIScopeAction = async (ctx, threadId, action) => {
  // Gets agent participant instead of human
  const agentUser = participants.find(p => p.userType === 'agent')
  const assignments = await getAssignments(agentUser._id) // WRONG - agent has no assignments!
}
```

**Why:** AI acts on behalf of human user, inherits their permissions, not independent actor.

### 17. Tool Return Format

**Rule:** Tools must return `{ content, metadata?, isError? }` format for Claude SDK.

```typescript
// ✅ DO: Proper return format
return {
  content: [{
    type: 'text' as const,
    text: `Draft created for review.`,
  }],
  metadata: { draftId }, // Optional metadata
}

// On error
return {
  content: [{
    type: 'text' as const,
    text: `Cannot create: ${error.message}`,
  }],
  isError: true,
}

// ❌ DON'T: Return plain string or throw
return "Draft created" // Wrong format
throw new Error("Failed") // Breaks AI flow
```

