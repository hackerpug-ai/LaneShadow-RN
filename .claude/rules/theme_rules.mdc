## Color Usage Guidelines

### Text Colors

```typescript
// ✅ DO: Use Paper Text with appropriate variants and color roles
import { Text } from 'react-native-paper'
const { semantic } = useSemanticTheme()

// Primary text
<Text variant="bodyLarge" style={{ color: semantic.color.onSurface.default }}>Main Text</Text>

// Secondary text
<Text variant="bodyMedium" style={{ color: semantic.color.onSurface.muted }}>Secondary Text</Text>

// Subtle/hint text
<Text variant="bodySmall" style={{ color: semantic.color.onSurface.subtle }}>Hint Text</Text>

// Text on colored backgrounds
<Text variant="labelMedium" style={{ color: semantic.color.onPrimary.default }}>On Primary</Text>

// ❌ DON'T: Use React Native Text or hardcoded colors
import { Text } from 'react-native' // WRONG - use Paper
<Text style={{ color: '#1C1B1F' }}>Text</Text>
<Text style={{ color: '#49454F' }}>Text</Text>
```

### Background Colors

```typescript
// ✅ DO: Use semantic surface colors
const { semantic } = useSemanticTheme()

// Primary surface
<View style={{ backgroundColor: semantic.color.surface.default }} />

// Alternate surface
<View style={{ backgroundColor: semantic.color.surfaceVariant.default }} />

// App background
<View style={{ backgroundColor: semantic.color.background.default }} />

// Card backgrounds
<View style={{ backgroundColor: semantic.color.card.default }} />

// ❌ DON'T: Use hardcoded backgrounds
<View style={{ backgroundColor: '#F5F5F5' }} />
<View style={{ backgroundColor: '#FFFFFF' }} />
```

### Intent/Status Colors

```typescript
// ✅ DO: Use semantic intent colors
const { semantic } = useSemanticTheme()

// Success
<View style={{ backgroundColor: semantic.color.success.default }}>
  <Text style={{ color: semantic.color.onPrimary.default }}>Success!</Text>
</View>

// Warning
<View style={{ backgroundColor: semantic.color.warning.default }}>
  <Text style={{ color: semantic.color.onPrimary.default }}>Warning!</Text>
</View>

// Danger/Error
<View style={{ backgroundColor: semantic.color.danger.default }}>
  <Text style={{ color: semantic.color.onPrimary.default }}>Error!</Text>
</View>

// Info
<View style={{ backgroundColor: semantic.color.info.default }}>
  <Text style={{ color: semantic.color.onPrimary.default }}>Info</Text>
</View>

// ❌ DON'T: Use hardcoded status colors
<View style={{ backgroundColor: '#198754' }} />
<View style={{ backgroundColor: '#B3261E' }} />
```

## Spacing Guidelines

```typescript
// ✅ DO: Use semantic spacing
const { semantic } = useSemanticTheme()

<View style={{
  padding: semantic.space.lg,        // 16
  marginBottom: semantic.space.md,   // 12
  gap: semantic.space.sm,            // 8
  paddingHorizontal: semantic.space.xl, // 24
}} />

// ❌ DON'T: Use hardcoded spacing
<View style={{
  padding: 16,
  marginBottom: 12,
  gap: 8,
}} />
```

### Spacing Scale Reference
- `xs`: 4px - Tiny gaps
- `sm`: 8px - Small gaps
- `md`: 12px - Medium gaps
- `lg`: 16px - Standard padding
- `xl`: 24px - Large padding
- `2xl`: 32px - Extra large padding
- `3xl`: 48px - Section spacing
- `4xl`: 64px - Major section spacing

## Typography Guidelines

```typescript
// ✅ DO: Use semantic typography
const { semantic } = useSemanticTheme()

// Display (hero text)
<Text style={semantic.type.display.lg}>Hero Title</Text>

// Headings (section titles)
<Text style={semantic.type.heading.md}>Section Title</Text>

// Titles (component titles)
<Text style={semantic.type.title.lg}>Card Title</Text>

// Body text (paragraphs)
<Text style={semantic.type.body.md}>Paragraph content here.</Text>

// Labels (UI labels)
<Text style={semantic.type.label.sm}>LABEL</Text>

// ❌ DON'T: Use hardcoded typography
<Text style={{ fontSize: 16, lineHeight: 24, fontWeight: '400' }}>Text</Text>
<Text style={{ fontSize: 22, fontWeight: '500' }}>Title</Text>
```

## Border Radius Guidelines

```typescript
// ✅ DO: Use semantic radius
const { semantic } = useSemanticTheme()

<View style={{
  borderRadius: semantic.radius.lg,      // 12 - cards, buttons
  borderRadius: semantic.radius.md,      // 8 - inputs, chips
  borderRadius: semantic.radius.full,    // 9999 - circular buttons
}} />

// ❌ DON'T: Use hardcoded radius
<View style={{ borderRadius: 12 }} />
<View style={{ borderRadius: 8 }} />
```

## Component Variants

### Button Variants

```typescript
// ✅ DO: Create semantic variants
import { Pressable, Text } from 'react-native'
import { useSemanticTheme } from '@/hooks/use-semantic-theme'

type ButtonVariant = 'primary' | 'success' | 'warning' | 'danger'

export const Button = ({ 
  variant = 'primary',
  onPress,
  disabled = false 
}) => {
  const { semantic } = useSemanticTheme()
  
  const getColors = () => {
    switch (variant) {
      case 'success':
        return {
          bg: semantic.color.success,
          text: semantic.color.onPrimary.default,
        }
      case 'warning':
        return {
          bg: semantic.color.warning,
          text: semantic.color.onPrimary.default,
        }
      case 'danger':
        return {
          bg: semantic.color.danger,
          text: semantic.color.onPrimary.default,
        }
      default:
        return {
          bg: semantic.color.primary,
          text: semantic.color.onPrimary.default,
        }
    }
  }
  
  const colors = getColors()
  
  return (
    <Pressable onPress={onPress} disabled={disabled}>
      {({ pressed }) => (
        <View style={{
          padding: semantic.space.md,
          backgroundColor: disabled
            ? colors.bg.disabled
            : pressed
            ? colors.bg.pressed
            : colors.bg.default,
          borderRadius: semantic.radius.lg,
        }}>
          <Text style={{
            ...semantic.type.label.md,
            color: colors.text,
          }}>
            Button
          </Text>
        </View>
      )}
    </Pressable>
  )
}
```

## Dark Mode

**Automatic Dark Mode Support**

The semantic theme automatically handles light/dark mode based on device settings. No manual dark mode logic needed!

```typescript
// ✅ DO: Semantic colors automatically handle dark mode
const { semantic } = useSemanticTheme()

<View style={{
  backgroundColor: semantic.color.surface.default, // Auto light/dark
  color: semantic.color.onSurface.default,        // Auto light/dark
}} />

// ❌ DON'T: Manual dark mode detection
import { useColorScheme } from 'react-native'

const colorScheme = useColorScheme()
<View style={{
  backgroundColor: colorScheme === 'dark' ? '#1C1B1F' : '#FFFFFF',
}} />
```

## Validation Checklist

Before committing component code:

- [ ] **Text component is from Paper**: `import { Text } from 'react-native-paper'`
- [ ] **Text uses Paper variants**: `variant="titleLarge"`, `variant="bodyMedium"`, etc.
- [ ] No hardcoded hex colors (`#6750A4`, `#FFFFFF`, etc.)
- [ ] No hardcoded spacing values (`16`, `24`, `padding: 8`, etc.)
- [ ] No hardcoded typography (`fontSize: 16`, `fontWeight: '500'`, etc.)
- [ ] All colors use `semantic.color.*`
- [ ] All spacing uses `semantic.space.*`
- [ ] All typography uses `semantic.type.*` (only when Paper variant not available)
- [ ] All border radius uses `semantic.radius.*`
- [ ] Interactive states use appropriate state colors (pressed, disabled, etc.)
- [ ] Component works in both light and dark modes

## Common Patterns

### Card Component

```typescript
import { View } from 'react-native'
import { Text } from 'react-native-paper'
import { useSemanticTheme } from '@/hooks/use-semantic-theme'

export const Card = ({ title, children }) => {
  const { semantic } = useSemanticTheme()
  
  return (
    <View style={{
      backgroundColor: semantic.color.card.default,
      borderRadius: semantic.radius.lg,
      borderWidth: 1,
      borderColor: semantic.color.border.default,
      padding: semantic.space.lg,
    }}>
      {title && (
        <Text variant="titleMedium" style={{ color: semantic.color.onSurface.default }}>
          {title}
        </Text>
      )}
      {children}
    </View>
  )
}
```

### Input Component

```typescript
export const Input = ({ value, onChangeText, placeholder }) => {
  const { semantic } = useSemanticTheme()
  
  return (
    <TextInput
      value={value}
      onChangeText={onChangeText}
      placeholder={placeholder}
      placeholderTextColor={semantic.color.onSurface.subtle}
      style={{
        ...semantic.type.body.md,
        backgroundColor: semantic.color.input.default,
        borderRadius: semantic.radius.md,
        borderWidth: 1,
        borderColor: semantic.color.border.default,
        padding: semantic.space.md,
        color: semantic.color.onSurface.default,
      }}
    />
  )
}
```

### List Item Component

```typescript
import { Pressable, View } from 'react-native'
import { Text } from 'react-native-paper'
import { useSemanticTheme } from '@/hooks/use-semantic-theme'

export const ListItem = ({ title, onPress, active = false }) => {
  const { semantic } = useSemanticTheme()
  
  return (
    <Pressable onPress={onPress}>
      {({ pressed }) => (
        <View style={{
          padding: semantic.space.md,
          backgroundColor: active
            ? semantic.color.primary.default
            : pressed
            ? semantic.color.surface.pressed
            : semantic.color.surface.default,
          borderRadius: semantic.radius.md,
        }}>
          <Text
            variant="bodyMedium"
            style={{
              color: active
                ? semantic.color.onPrimary.default
                : semantic.color.onSurface.default,
            }}
          >
            {title}
          </Text>
        </View>
      )}
    </Pressable>
  )
}
```

