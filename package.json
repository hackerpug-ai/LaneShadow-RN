{
  "name": "laneshadow",
  "main": "./react-native/index.js",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm server:dev & pnpm client:dev",
    "client:dev": "pnpm --dir react-native exec expo start --ios",
    "server:dev": "pnpm --dir server dev",
    "server:deploy": "pnpm --dir server deploy",
    "server:codegen": "pnpm --dir server codegen",
    "server:dashboard": "pnpm --dir server dashboard",
    "native:ios": "pnpm --dir react-native exec expo prebuild --platform ios",
    "pods:ios": "pnpm --dir react-native exec expo run:ios",
    "native:android": "pnpm --dir react-native exec expo prebuild --platform android",
    "start": "pnpm --dir react-native exec expo start",
    "android": "pnpm --dir react-native exec expo run:android",
    "ios": "pnpm --dir react-native exec expo run:ios",
    "web": "pnpm --dir react-native exec expo start --web",
    "type-check": "pnpm --dir react-native exec tsc --noEmit",
    "typecheck": "pnpm type-check",
    "type-check:native": "pnpm --dir react-native exec tsgo --noEmit",
    "type-check:benchmark": "echo '=== tsc ===' && time pnpm type-check; echo '=== tsgo ===' && time pnpm type-check:native",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "format:ios": "swiftformat react-native/ios/LaneShadow --config .swiftformat",
    "test": "pnpm --dir react-native exec vitest",
    "test:watch": "pnpm --dir react-native exec vitest --watch",
    "test:ui": "pnpm --dir react-native exec vitest --ui",
    "storybook:generate": "pnpm --dir react-native exec sb-rn-get-stories",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true pnpm --dir react-native exec expo start --clear",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true pnpm --dir react-native exec expo run:ios",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK_ENABLED=true pnpm --dir react-native exec expo run:android",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
    "@clerk/backend": "^1.9.0",
    "@clerk/clerk-expo": "^2.19.17",
    "@convex-dev/geospatial": "^0.2.1",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
