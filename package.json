  "devDependencies": {
    "@aws-sdk/lib-storage": "^3.1026.0",
    "@biomejs/biome": "^2.4.12",
    "@langchain/core": "^1.1.12",
    "@langchain/langgraph": "^1.0.15",
    "@langchain/openai": "^1.2.1",
    "@storybook/addon-ondevice-actions": "^10.2.3",
    "@storybook/addon-ondevice-controls": "^10.2.3",
    "@storybook/react-native": "^10.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.18.10",
    "@types/pbf": "^3.0.5",
    "@types/react": "~19.1.17",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "@vitest/ui": "^3.0.9",
    "dotenv": "^16.6.0",
    "jsdom": "^29.0.1",
    "langchain": "^1.2.7",
    "langsmith": "^0.5.16",
    "lefthook": "^2.1.6",
    "react-test-renderer": "19.1.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.2",
    "vitest": "^3.0.9"
  },
  "private": true,
  "packageManager": "pnpm@8.15.1+sha1.8adba2d20330c02d3856e18c4eb3819d1d3ca6aa"
}
