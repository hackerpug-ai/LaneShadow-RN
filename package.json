{
  "name": "laneshadow",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "pnpm convex:dev & pnpm client:dev",
    "dev:all": "pnpm convex:dev & pnpm client:dev",
    "client:dev": "npx expo start --dev-client --ios",
    "server:dev": "pnpm convex:dev",
    "convex:dev": "npx convex dev",
    "convex:codegen": "npx convex codegen",
    "convex:deploy": "npx convex deploy",
    "convex:dashboard": "npx convex dashboard",
    "convex:health": "node scripts/check-convex-health.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "build:ios": "expo run:ios --device",
    "build:ios:tf": "eas build --platform ios --profile production --auto-submit",
    "submit:ios": "eas submit --platform ios --profile production --latest",
    "devices:list": "xcrun devicectl list devices",
    "web": "expo start --web",
    "type-check": "tsc --noEmit -p convex/tsconfig.json && tsc --noEmit -p tsconfig.json",
    "server:codegen": "npx tsx scripts/generate-mobile-types.ts",
    "tokens:validate": "node tokens/scripts/validate-contract.js && pnpm tsx tokens/scripts/validate-typography.ts && pnpm tsx tokens/scripts/validate-dimensions.ts && node tokens/scripts/validate-colors.js",
    "tokens:generate": "pnpm tsx tokens/scripts/generate.ts",
    "tokens:sync-check": "pnpm tsx tokens/scripts/sync-check.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "storybook": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo start --clear",
    "storybook:ios": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:ios",
    "storybook:android": "EXPO_PUBLIC_STORYBOOK_ENABLED=true expo run:android",
    "prepare": "husky",
    "eas-build-post-install": "npx convex codegen"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
