#!/usr/bin/env sh

set -eu

APP_HOME=$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)
GRADLE_VERSION="8.7"
DIST_NAME="gradle-${GRADLE_VERSION}-bin"
DIST_ZIP="${DIST_NAME}.zip"
DIST_URL="https://services.gradle.org/distributions/${DIST_ZIP}"
CACHE_ROOT="${HOME}/.gradle/wrapper/dists"
INSTALL_DIR="${CACHE_ROOT}/${DIST_NAME}"
GRADLE_BIN="${INSTALL_DIR}/gradle-${GRADLE_VERSION}/bin/gradle"

if [ ! -x "${GRADLE_BIN}" ]; then
  mkdir -p "${INSTALL_DIR}"
  TMP_ZIP="${INSTALL_DIR}/${DIST_ZIP}.tmp"
  if [ ! -f "${TMP_ZIP}" ]; then
    echo "Downloading ${DIST_URL}"
    curl -fsSL "${DIST_URL}" -o "${TMP_ZIP}"
  fi
  unzip -qo "${TMP_ZIP}" -d "${INSTALL_DIR}"
fi

exec "${GRADLE_BIN}" -p "${APP_HOME}" "$@"
