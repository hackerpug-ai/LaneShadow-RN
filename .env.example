# Convex Backend Configuration
# Get your CONVEX_URL from: https://dashboard.convex.dev
# Format: https://your-project.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Add any other environment variables here as needed for your project
# Remember: Variables prefixed with EXPO_PUBLIC_ are exposed to the frontend
# Never commit sensitive variables to version control

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY
CLERK_TEST_EMAIL=e2e-login@YOUR_MAILOSAUR_DOMAIN
CLERK_TEST_PASSWORD=YOUR_CLERK_TEST_PASSWORD

CLERK_JWT_ISSUER_DOMAIN=YOUR_JWT_ISSUER_DOMAIN

CLERK_SECRET_KEY=YOUR_SECRET_KEY

MAILOSAUR_API_KEY=YOUR_MAILOSAUR_API_KEY
MAILOSAUR_SERVER_ID=YOUR_MAILOSAUR_SERVER_ID
MAILOSAUR_DOMAIN=YOUR_MAILOSAUR_DOMAIN

IOS_DEVELOPMENT_TEAM=YOUR_APPLE_TEAM_ID

EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY

# Mapbox Access Token
# Get your access token from: https://account.mapbox.com/
# Required scopes: downloads:read, styles:read, fonts:read
# This token is used by the @rnmapbox/maps Expo plugin
MAPBOX_ACCESS_TOKEN=YOUR_MAPBOX_ACCESS_TOKEN
# Cerebras API Key
# Required for AI agent models (zai-glm-4.7, qwen-3-235b)
# Get your key from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=YOUR_CEREBRAS_API_KEY
